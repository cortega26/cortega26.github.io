---
interface Props { lang: 'en' | 'es'; }
const { lang } = Astro.props;

const en = {
  eyebrow: 'About', title: 'Who I Work With & How',
  intro: 'My strongest work starts from practical operational pain: data that arrives late, reporting that breaks easily, and workflows that depend too much on manual attention. I focus on solving the workflow first, then packaging the result so it is testable, documented, and easier to keep running.',
  cards: [
    { title: 'Who I help', icon: '👥', items: ['Operations-heavy teams still relying on spreadsheets, manual checks, or brittle scripts.', 'Founders and managers who need reliable internal tools without overbuilding a full product team.', 'Organizations that benefit from bilingual technical communication.'] },
    { title: 'What clients get', icon: '📦', items: ['Clear scope, documented assumptions, and honest tradeoffs before implementation starts.', 'Python-first delivery with CI, structured logging, deterministic outputs, and readable README docs.', 'Practical handoff materials so the workflow survives after the initial delivery.'] },
    { title: 'Preferred stack', icon: '⚙️', items: ['Python, SQL, Bash, FastAPI, Selenium, BeautifulSoup, Pandas, and static-site tooling.', 'GitHub Actions, CodeQL, package publishing, and docs-focused repository packaging.', 'Interfaces that reduce cognitive load for operators instead of adding more software to babysit.'] },
  ],
};

const es = {
  eyebrow: 'Perfil', title: 'Con quién trabajo y cómo',
  intro: 'Mi trabajo más sólido parte del dolor operativo concreto: datos que llegan tarde, reportes que se rompen fácilmente y flujos que dependen demasiado de atención manual. Me enfoco primero en resolver el flujo, luego en empaquetar el resultado para que sea testeable, documentado y más fácil de mantener.',
  cards: [
    { title: 'A quién ayudo', icon: '👥', items: ['Equipos con operaciones intensas que todavía dependen de hojas de cálculo, revisiones manuales o scripts frágiles.', 'Fundadores y gerentes que necesitan herramientas internas confiables sin armar un equipo de producto completo.', 'Organizaciones que se benefician de comunicación técnica bilingüe.'] },
    { title: 'Qué reciben los clientes', icon: '📦', items: ['Alcance claro, supuestos documentados y tradeoffs honestos antes de comenzar la implementación.', 'Entrega Python-first con CI, logging estructurado, salidas deterministas y READMEs legibles.', 'Materiales de traspaso prácticos para que el flujo sobreviva después de la entrega inicial.'] },
    { title: 'Stack preferido', icon: '⚙️', items: ['Python, SQL, Bash, FastAPI, Selenium, BeautifulSoup, Pandas y herramientas de sitios estáticos.', 'GitHub Actions, CodeQL, publicación de paquetes y empaquetado de repositorios orientado a docs.', 'Interfaces que reducen la carga cognitiva en lugar de agregar más software que supervisar.'] },
  ],
};

const c = lang === 'en' ? en : es;
---
<section class="section section--alt" id="about">
  <div class="container">
    <div class="section-header section-header--center">
      <span class="section-eyebrow reveal">{c.eyebrow}</span>
      <h2 class="section-title reveal">{c.title}</h2>
      <div class="divider reveal"></div>
      <p class="section-subtitle reveal">{c.intro}</p>
    </div>
    <div class="grid-3">
      {c.cards.map((card, i) => (
        <article class={`card-glass reveal reveal-delay-${i + 1}`}>
          <div class="about-icon">{card.icon}</div>
          <h3 class="about-card-title">{card.title}</h3>
          <ul class="about-list">
            {card.items.map(item => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.about-icon { font-size: 1.75rem; margin-bottom: 0.75rem; }
.about-card-title {
  font-family: var(--ff-heading); font-size: 1rem; font-weight: 700;
  color: var(--clr-text); margin-bottom: 0.75rem;
}
.about-list { display: flex; flex-direction: column; gap: 0.6rem; }
.about-list li {
  font-size: 0.88rem; color: var(--clr-text-muted); line-height: 1.55;
  padding-left: 1rem; position: relative;
}
.about-list li::before {
  content: '›'; position: absolute; left: 0;
  color: var(--clr-accent); font-weight: 700;
}
</style>
