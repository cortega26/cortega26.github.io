---
interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const en = {
  eyebrow: "Contact",
  title: "Project Brief",
  subtitle:
    "Send the workflow, the bottleneck, and the outcome you want.",
  copy: "The cleanest starting point is the form. A short message is enough if it includes what is breaking, what should happen instead, and who operates the workflow today.",
  preferred:
    "Best fit: scoped automation, reporting pipelines, data cleanup, internal tools, and stabilization work that needs a clear handoff.",
  primaryLabel: "Primary contact",
  emailAddress: "carlos@tooltician.com",
  emailDirect: "Email instead",
  emailHref: "mailto:carlos@tooltician.com?subject=Project%20Inquiry",
  copyEmail: "Copy address",
  copied: "Address copied.",
  schedule: "Book intro call",
  scheduleAria: "Schedule an intro call on Calendly",
  linkedinLabel: "LinkedIn profile",
  linkedinCta: "View LinkedIn",
  formTitle: "Brief form",
  formIntro: "If the scope is already clear in writing, leave it here and I’ll reply by email.",
  defaultSubject: "Project brief from tooltician.com",
  nameLabel: "Name",
  namePh: "Your name",
  emailLabel: "Email",
  emailPh: "your@email.com",
  messageLabel: "Project brief",
  messagePh:
    "Describe the workflow, the bottleneck, and the outcome you want...",
  submit: "Send brief",
  submitSending: "Sending…",
  successMsg: "Message sent. I’ll reply within two business days.",
  errorMsg:
    "Something went wrong. Please email me directly at carlos@tooltician.com.",
};

const es = {
  eyebrow: "Contacto",
  title: "Brief del proyecto",
  subtitle:
    "Envía el flujo, el cuello de botella y el resultado que quieres.",
  copy: "La forma más limpia de partir es el formulario. Un mensaje corto basta si incluye qué está fallando, qué debería pasar y quién opera hoy el flujo.",
  preferred:
    "Mejor encaje: automatización acotada, pipelines de reportes, limpieza de datos, herramientas internas y trabajo de estabilización con traspaso claro.",
  primaryLabel: "Correo principal",
  emailAddress: "carlos@tooltician.com",
  emailDirect: "Correo directo",
  emailHref: "mailto:carlos@tooltician.com?subject=Consulta%20de%20Proyecto",
  copyEmail: "Copiar dirección",
  copied: "Dirección copiada.",
  schedule: "Agendar llamada inicial",
  scheduleAria: "Agendar una llamada inicial en Calendly",
  linkedinLabel: "Perfil de LinkedIn",
  linkedinCta: "Ver LinkedIn",
  formTitle: "Formulario de brief",
  formIntro: "Si el alcance ya está claro por escrito, déjalo aquí y te respondo por correo.",
  defaultSubject: "Brief de proyecto desde tooltician.com",
  nameLabel: "Nombre",
  namePh: "Tu nombre",
  emailLabel: "Correo",
  emailPh: "tu@correo.com",
  messageLabel: "Brief del proyecto",
  messagePh: "Describe el flujo, el problema y el resultado que quieres...",
  submit: "Enviar brief",
  submitSending: "Enviando…",
  successMsg: "Mensaje enviado. Respondo en dos días hábiles.",
  errorMsg:
    "Algo salió mal. Escríbeme directamente a carlos@tooltician.com.",
};

const c = lang === "en" ? en : es;
---

<section class="section" id="contact">
  <div class="container">
    <div class="section-header section-header--center">
      <span class="section-eyebrow reveal">{c.eyebrow}</span>
      <h2 class="section-title reveal">{c.title}</h2>
      <div class="divider reveal"></div>
      <p class="section-subtitle reveal">{c.subtitle}</p>
    </div>

    <div class="contact-layout">
      <div class="contact-info reveal">
        <p class="contact-copy">{c.copy}</p>
        <p class="contact-preferred">{c.preferred}</p>

        <div class="contact-primary">
          <p class="contact-primary__label">{c.primaryLabel}</p>
          <p class="contact-primary__value">{c.emailAddress}</p>
        </div>

        <div class="contact-actions">
          <a
            class="btn btn-primary"
            href="https://calendly.com/ciortega26"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={c.scheduleAria}>{c.schedule}</a
          >
          <a class="btn btn-ghost" href={c.emailHref}>
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              aria-hidden="true"
            >
              <path d="M4 4h16v16H4z" opacity="0"></path>
              <path d="m4 8 8 6 8-6"></path>
              <rect x="3" y="5" width="18" height="14" rx="2"></rect>
            </svg>
            {c.emailDirect}
          </a>
          <button
            class="btn btn-ghost copy-email-btn"
            type="button"
            data-email={c.emailAddress}
            aria-label={lang === "en" ? "Copy email address" : "Copiar correo"}
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              aria-hidden="true"
            >
              <rect width="8" height="4" x="8" y="2" rx="1" ry="1"></rect>
              <path
                d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"
              ></path>
            </svg>
            {c.copyEmail}
          </button>
        </div>

        <p class="copy-confirm" id="copy-confirm" aria-live="polite">
          {c.copied}
        </p>

        <p class="contact-inline-link">
          <span>{c.linkedinLabel}:</span>
          <a
            href="https://www.linkedin.com/in/cortega26"
            target="_blank"
            rel="noopener noreferrer">{c.linkedinCta}</a
          >
        </p>
      </div>

      <form
        class="contact-form reveal reveal-delay-1"
        id="contact-form"
        action="https://formspree.io/f/mgorrygb"
        method="POST"
        novalidate
      >
        <div class="form-heading">
          <h3>{c.formTitle}</h3>
          <p>{c.formIntro}</p>
        </div>
        <input type="hidden" name="subject" value={c.defaultSubject} />

        <div class="form-group">
          <label for="cf-name">{c.nameLabel}</label>
          <input
            type="text"
            id="cf-name"
            name="name"
            placeholder={c.namePh}
            required
            autocomplete="name"
          />
        </div>
        <div class="form-group">
          <label for="cf-email">{c.emailLabel}</label>
          <input
            type="email"
            id="cf-email"
            name="email"
            placeholder={c.emailPh}
            required
            autocomplete="email"
          />
        </div>
        <div class="form-group">
          <label for="cf-message">{c.messageLabel}</label>
          <textarea
            id="cf-message"
            name="message"
            rows={5}
            placeholder={c.messagePh}
            required></textarea>
        </div>
        <button
          type="submit"
          class="btn btn-primary"
          id="cf-submit"
          data-sending={c.submitSending}>{c.submit}</button
        >
        <p
          class="form-success"
          id="form-success"
          aria-live="polite"
          role="status"
        >
          {c.successMsg}
        </p>
        <p class="form-error" id="form-error" aria-live="polite" role="alert">
          {c.errorMsg}
        </p>
      </form>
    </div>
  </div>
</section>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(0, 1.22fr);
    gap: 2rem;
    align-items: start;
  }

  .contact-info {
    border-top: 1px solid var(--clr-border);
    padding-top: 1rem;
  }

  .contact-copy {
    font-size: 0.95rem;
    color: var(--clr-text);
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .contact-preferred {
    font-size: 0.85rem;
    color: var(--clr-text-faint);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .contact-primary {
    padding-top: 1rem;
    margin-bottom: 1rem;
    border-top: 1px solid var(--clr-border);
  }

  .contact-primary__label {
    font-family: var(--ff-label);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--clr-text-faint);
    margin-bottom: 0.3rem;
  }

  .contact-primary__value {
    font-size: 1rem;
    font-weight: 600;
    color: var(--clr-text);
    overflow-wrap: anywhere;
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-bottom: 0.75rem;
  }

  .copy-confirm {
    font-size: 0.8rem;
    color: var(--clr-accent);
    opacity: 0;
    transition: opacity 300ms;
    font-weight: 600;
    min-height: 1.25rem;
    margin-bottom: 0.8rem;
  }

  .copy-confirm.show {
    opacity: 1;
  }

  .contact-inline-link {
    font-size: 0.84rem;
    color: var(--clr-text-muted);
  }

  .contact-inline-link span {
    color: var(--clr-text-faint);
    margin-right: 0.35rem;
  }

  .contact-inline-link a {
    color: var(--clr-accent);
    font-weight: 600;
  }

  .contact-inline-link a:hover {
    color: var(--clr-accent-hover);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1rem;
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-md);
    background: var(--clr-surface);
  }

  .form-heading {
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--clr-border);
  }

  .form-heading h3 {
    font-family: var(--ff-heading);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.35rem;
    color: var(--clr-text);
  }

  .form-heading p {
    font-size: 0.88rem;
    color: var(--clr-text-muted);
    line-height: 1.6;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-family: var(--ff-label);
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--clr-text-faint);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .form-group input,
  .form-group textarea {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-sm);
    padding: 0.8rem 0.95rem;
    font-family: var(--ff-body);
    font-size: 0.9rem;
    color: var(--clr-text);
    transition:
      border-color 150ms,
      box-shadow 150ms;
    resize: vertical;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--clr-accent);
    box-shadow: 0 0 0 3px rgba(196, 160, 74, 0.1);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--clr-text-faint);
  }

  .form-success,
  .form-error {
    display: none;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.6rem 0.9rem;
    border-radius: var(--radius-sm);
  }

  .form-success {
    color: var(--clr-accent);
    background: rgba(196, 160, 74, 0.08);
    border: 1px solid rgba(196, 160, 74, 0.15);
  }

  .form-error {
    color: #f87171;
    background: rgba(248, 113, 113, 0.08);
    border: 1px solid rgba(248, 113, 113, 0.15);
  }

  .form-success.show,
  .form-error.show {
    display: block;
  }

  @media (max-width: 768px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const copyBtn = document.querySelector<HTMLButtonElement>(".copy-email-btn");
  const copyConfirm = document.getElementById("copy-confirm");
  copyBtn?.addEventListener("click", async () => {
    const email = copyBtn.dataset.email ?? "";
    try {
      await navigator.clipboard.writeText(email);
      copyConfirm?.classList.add("show");
      setTimeout(() => copyConfirm?.classList.remove("show"), 2500);
    } catch {
      window.location.href = "mailto:" + email;
    }
  });

  const form = document.getElementById(
    "contact-form",
  ) as HTMLFormElement | null;
  const submitBtn = document.getElementById(
    "cf-submit",
  ) as HTMLButtonElement | null;
  const successEl = document.getElementById("form-success");
  const errorEl = document.getElementById("form-error");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const originalLabel = submitBtn?.textContent ?? "";
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = submitBtn.dataset.sending ?? "Sending…";
    }
    successEl?.classList.remove("show");
    errorEl?.classList.remove("show");

    try {
      const res = await fetch(form.action, {
        method: "POST",
        body: new FormData(form),
        headers: { Accept: "application/json" },
      });
      if (res.ok) {
        form.reset();
        successEl?.classList.add("show");
      } else {
        errorEl?.classList.add("show");
      }
    } catch {
      errorEl?.classList.add("show");
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = originalLabel;
      }
    }
  });
</script>
