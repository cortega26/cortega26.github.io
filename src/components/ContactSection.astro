---
interface Props {
  lang: "en" | "es";
}
const { lang } = Astro.props;

const en = {
  eyebrow: "Contact",
  title: "Project Brief",
  subtitle:
    "Send the workflow, the bottleneck, the current owner, and the outcome you want.",
  copy: "Use the form as the starting point. A short note is enough — cover the workflow, the bottleneck, and what a good result looks like.",
  preferred:
    "Fit: scoped automation, ETL cleanup, scraping, and internal tools with a clear owner. Not fit: open-ended discovery without a concrete workflow.",
  availability: "Currently open for new scoped engagements.",
  briefChecklistTitle: "Useful in the first note",
  briefChecklist: [
    "Current workflow and tools involved.",
    "Main bottleneck, failure, or review risk.",
    "Desired output and who will operate it.",
    "Deadline, cadence, or handoff constraint.",
  ],
  primaryLabel: "Primary contact",
  emailAddress: "carlos@tooltician.com",
  emailDirect: "Email instead",
  emailHref: "mailto:carlos@tooltician.com?subject=Project%20Inquiry",
  copyEmail: "Copy address",
  copied: "Address copied.",
  schedule: "Book intro call",
  scheduleAria: "Schedule an intro call on Calendly",
  linkedinLabel: "LinkedIn profile",
  linkedinCta: "View LinkedIn",
  formTitle: "Brief form",
  formIntro: "If the scope is already clear in writing, leave it here and I’ll reply by email with fit, next questions, or a direct no if it sits outside scope.",
  policyLead:
    "By sending this form, you agree to a reply by email. Delivery uses Formspree, scheduling uses Calendly, and language preference is stored locally in your browser. See",
  policyJoin: "and",
  privacyLink: "Privacy",
  cookiesLink: "Cookies",
  defaultSubject: "Project brief from tooltician.com",
  nameLabel: "Name",
  namePh: "Your name",
  emailLabel: "Email",
  emailPh: "your@email.com",
  messageLabel: "Project brief",
  messagePh:
    "Workflow and tools · Main bottleneck or failure · Who will operate it · Deadline or handoff constraint",
  callAlt: "If you’d rather not type, book a 20-min call.",
  replyNote: "Reply within 2 business days · Direct yes/no on fit · Free 30-min scoping call if it’s a fit · No sales sequence.",
  submit: "Send brief",
  submitSending: "Sending…",
  successMsg: "Message sent. I’ll reply within two business days.",
  errorMsg:
    "Something went wrong. Please email me directly at carlos@tooltician.com.",
  serviceLead: undefined as string | undefined,
  serviceCta: undefined as string | undefined,
  serviceHref: undefined as string | undefined,
};

const es = {
  eyebrow: "Contacto",
  title: "Brief del proyecto",
  subtitle:
    "Envía el flujo, el cuello de botella, el responsable actual y el resultado que quieres.",
  copy: "El formulario es el punto de partida más limpio. Un mensaje corto basta — incluye el flujo, el cuello de botella y cómo se ve un buen resultado.",
  preferred:
    "Encaja: automatización acotada, limpieza ETL, scraping y herramientas internas con owner claro. No encaja: discovery abierto sin flujo concreto.",
  availability: "Actualmente disponible para nuevos proyectos acotados.",
  briefChecklistTitle: "Útil en el primer mensaje",
  briefChecklist: [
    "Flujo actual y herramientas involucradas.",
    "Principal cuello de botella, falla o riesgo de revisión.",
    "Salida esperada y quién la va a operar.",
    "Deadline, cadencia o restricción de traspaso.",
  ],
  primaryLabel: "Correo principal",
  emailAddress: "carlos@tooltician.com",
  emailDirect: "Correo directo",
  emailHref: "mailto:carlos@tooltician.com?subject=Consulta%20de%20Proyecto",
  copyEmail: "Copiar dirección",
  copied: "Dirección copiada.",
  schedule: "Agendar llamada inicial",
  scheduleAria: "Agendar una llamada inicial en Calendly",
  linkedinLabel: "Perfil de LinkedIn",
  linkedinCta: "Ver LinkedIn",
  serviceLead: "Si tu problema no es un flujo interno nuevo sino un sitio ya publicado que necesita revisión técnica periódica, parte por",
  serviceCta: "Diagnóstico Técnico Web",
  serviceHref: "/es/servicios/higiene-tecnica-web/",
  formTitle: "Formulario de brief",
  formIntro: "Si el alcance ya está claro por escrito, déjalo aquí y te respondo por correo con encaje, preguntas siguientes o un no directo si queda fuera de alcance.",
  policyLead:
    "Al enviar este formulario, aceptas que la respuesta llegue por correo. El envío usa Formspree, la agenda usa Calendly y la preferencia de idioma se guarda localmente en tu navegador. Revisa",
  policyJoin: "y",
  privacyLink: "Privacidad",
  cookiesLink: "Cookies",
  defaultSubject: "Brief de proyecto desde tooltician.com",
  nameLabel: "Nombre",
  namePh: "Tu nombre",
  emailLabel: "Correo",
  emailPh: "tu@correo.com",
  messageLabel: "Brief del proyecto",
  messagePh: "Flujo y herramientas · Cuello de botella principal · Quién lo va a operar · Deadline o restricción de traspaso",
  callAlt: "Si preferís no escribir, agenda una llamada de 20 min.",
  replyNote: "Respuesta en 2 días hábiles · Sí o no directo según encaje · Llamada de scoping de 30 min si hay encaje · Sin secuencia de ventas.",
  submit: "Enviar brief",
  submitSending: "Enviando…",
  successMsg: "Mensaje enviado. Respondo en dos días hábiles.",
  errorMsg:
    "Algo salió mal. Escríbeme directamente a carlos@tooltician.com.",
};

const c = lang === "en" ? en : es;
---

<section class="section" id="contact">
  <div class="container">
    <div class="section-header section-header--center">
      <span class="section-eyebrow reveal">{c.eyebrow}</span>
      <h2 class="section-title reveal">{c.title}</h2>
      <div class="divider reveal"></div>
      <p class="section-subtitle reveal">{c.subtitle}</p>
    </div>

    <div class="contact-layout">
      <div class="contact-info reveal">
        <p class="contact-copy">{c.copy}</p>
        <p class="contact-preferred">{c.preferred}</p>
        <p class="contact-availability">{c.availability}</p>
        <p class="contact-checklist-title">{c.briefChecklistTitle}</p>
        <ul class="contact-checklist">
          {c.briefChecklist.map(item => (
            <li>{item}</li>
          ))}
        </ul>

        <div class="contact-primary">
          <p class="contact-primary__label">{c.primaryLabel}</p>
          <p class="contact-primary__value">{c.emailAddress}</p>
        </div>

        <div class="contact-actions">
          <a
            class="btn btn-primary"
            href="https://calendly.com/ciortega26"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={c.scheduleAria}>{c.schedule}</a
          >
          <a class="btn btn-ghost" href={c.emailHref}>
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              aria-hidden="true"
            >
              <path d="M4 4h16v16H4z" opacity="0"></path>
              <path d="m4 8 8 6 8-6"></path>
              <rect x="3" y="5" width="18" height="14" rx="2"></rect>
            </svg>
            {c.emailDirect}
          </a>
          <button
            class="btn btn-ghost copy-email-btn"
            type="button"
            data-email={c.emailAddress}
            aria-label={lang === "en" ? "Copy email address" : "Copiar correo"}
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              aria-hidden="true"
            >
              <rect width="8" height="4" x="8" y="2" rx="1" ry="1"></rect>
              <path
                d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"
              ></path>
            </svg>
            {c.copyEmail}
          </button>
        </div>

        <p class="copy-confirm" id="copy-confirm" aria-live="polite">
          {c.copied}
        </p>

        <p class="contact-inline-link">
          <span>{c.linkedinLabel}:</span>
          <a
            href="https://www.linkedin.com/in/cortega26"
            target="_blank"
            rel="noopener noreferrer">{c.linkedinCta}</a
          >
        </p>
        {c.serviceLead && (
          <p class="contact-service-link">
            <span>{c.serviceLead}</span>
            <a href={c.serviceHref}>{c.serviceCta}</a>.
          </p>
        )}
      </div>

      <form
        class="contact-form reveal reveal-delay-1"
        id="contact-form"
        action="https://formspree.io/f/mgorrygb"
        method="POST"
        novalidate
      >
        <div class="form-heading">
          <h3>{c.formTitle}</h3>
          <p>{c.formIntro}</p>
          <p class="form-call-alt">
            {c.callAlt}{" "}
            <a href="https://calendly.com/ciortega26" target="_blank" rel="noopener noreferrer">
              {lang === "en" ? "Book here →" : "Agendar aquí →"}
            </a>
          </p>
          <p class="form-policy-note">
            {c.policyLead}{' '}
            <a href={lang === "en" ? "/en/privacy/" : "/es/privacy/"}>{c.privacyLink}</a>{' '}
            {c.policyJoin}{' '}
            <a href={lang === "en" ? "/en/cookies/" : "/es/cookies/"}>{c.cookiesLink}</a>.
          </p>
        </div>
        <input type="hidden" name="subject" value={c.defaultSubject} />

        <div class="form-group">
          <label for="cf-name">{c.nameLabel}</label>
          <input
            type="text"
            id="cf-name"
            name="name"
            placeholder={c.namePh}
            required
            autocomplete="name"
          />
        </div>
        <div class="form-group">
          <label for="cf-email">{c.emailLabel}</label>
          <input
            type="email"
            id="cf-email"
            name="email"
            placeholder={c.emailPh}
            required
            autocomplete="email"
          />
        </div>
        <div class="form-group">
          <label for="cf-message">{c.messageLabel}</label>
          <textarea
            id="cf-message"
            name="message"
            rows={5}
            placeholder={c.messagePh}
            required></textarea>
        </div>
        <div class="form-submit-group">
          <button
            type="submit"
            class="btn btn-primary"
            id="cf-submit"
            data-sending={c.submitSending}>{c.submit}</button
          >
          <p class="form-reply-note">{c.replyNote}</p>
        </div>
        <p
          class="form-success"
          id="form-success"
          aria-live="polite"
          role="status"
        >
          {c.successMsg}
        </p>
        <p class="form-error" id="form-error" aria-live="polite" role="alert">
          {c.errorMsg}
        </p>
      </form>
    </div>
  </div>
</section>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(0, 1.22fr);
    gap: 2rem;
    align-items: start;
  }

  .contact-info {
    border-top: 1px solid var(--clr-border);
    padding-top: 1rem;
  }

  .contact-copy {
    font-size: 0.95rem;
    color: var(--clr-text);
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .contact-preferred {
    font-size: 0.85rem;
    color: var(--clr-text-faint);
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .contact-availability {
    font-size: 0.85rem;
    color: var(--clr-accent);
    line-height: 1.6;
    margin-bottom: 0.85rem;
    font-weight: 600;
  }

  .contact-checklist-title {
    font-family: var(--ff-label);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--clr-text-faint);
    margin-bottom: 0.5rem;
  }

  .contact-checklist {
    display: grid;
    gap: 0.45rem;
    margin-bottom: 1.5rem;
    color: var(--clr-text-muted);
  }

  .contact-checklist li {
    font-size: 0.84rem;
    line-height: 1.55;
    padding-left: 1rem;
    position: relative;
  }

  .contact-checklist li::before {
    content: '›';
    position: absolute;
    left: 0;
    color: var(--clr-accent);
    font-weight: 700;
  }

  .contact-primary {
    padding-top: 1rem;
    margin-bottom: 1rem;
    border-top: 1px solid var(--clr-border);
  }

  .contact-primary__label {
    font-family: var(--ff-label);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--clr-text-faint);
    margin-bottom: 0.3rem;
  }

  .contact-primary__value {
    font-size: 1rem;
    font-weight: 600;
    color: var(--clr-text);
    overflow-wrap: anywhere;
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-bottom: 0.75rem;
  }

  .copy-confirm {
    font-size: 0.8rem;
    color: var(--clr-accent);
    opacity: 0;
    transition: opacity 300ms;
    font-weight: 600;
    min-height: 1.25rem;
    margin-bottom: 0.8rem;
  }

  .copy-confirm.show {
    opacity: 1;
  }

  .contact-inline-link {
    font-size: 0.84rem;
    color: var(--clr-text-muted);
  }

  .contact-inline-link span {
    color: var(--clr-text-faint);
    margin-right: 0.35rem;
  }

  .contact-inline-link a {
    color: var(--clr-accent);
    font-weight: 600;
  }

  .contact-inline-link a:hover {
    color: var(--clr-accent-hover);
  }

  .contact-service-link {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--clr-border);
    color: var(--clr-text-muted);
    font-size: 0.84rem;
    line-height: 1.65;
  }

  .contact-service-link a {
    color: var(--clr-accent);
    font-family: var(--ff-label);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-left: 0.2rem;
  }

  .contact-service-link a:hover {
    color: var(--clr-text);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1rem;
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-md);
    background: var(--clr-surface);
  }

  .form-heading {
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--clr-border);
  }

  .form-policy-note {
    font-size: 0.78rem;
    line-height: 1.6;
    color: var(--clr-text-faint);
    margin-top: 0.5rem;
  }

  .form-policy-note a {
    color: var(--clr-accent);
    font-weight: 600;
  }

  .form-policy-note a:hover {
    color: var(--clr-accent-hover);
  }

  .form-heading h3 {
    font-family: var(--ff-heading);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.35rem;
    color: var(--clr-text);
  }

  .form-heading p {
    font-size: 0.88rem;
    color: var(--clr-text-muted);
    line-height: 1.6;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-family: var(--ff-label);
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--clr-text-faint);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .form-group input,
  .form-group textarea {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-sm);
    padding: 0.8rem 0.95rem;
    font-family: var(--ff-body);
    font-size: 0.9rem;
    color: var(--clr-text);
    transition:
      border-color 150ms,
      box-shadow 150ms;
    resize: vertical;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--clr-accent);
    box-shadow: 0 0 0 3px rgba(196, 160, 74, 0.1);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--clr-text-faint);
  }

  .form-call-alt {
    font-size: 0.85rem;
    color: var(--clr-text-muted);
    margin-top: 0.5rem;
  }

  .form-call-alt a {
    color: var(--clr-accent);
    font-weight: 600;
  }

  .form-call-alt a:hover {
    color: var(--clr-accent-hover);
  }

  .form-submit-group {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .form-reply-note {
    font-size: 0.78rem;
    color: var(--clr-text-faint);
    line-height: 1.55;
  }

  .form-success,
  .form-error {
    display: none;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.6rem 0.9rem;
    border-radius: var(--radius-sm);
  }

  .form-success {
    color: var(--clr-accent);
    background: rgba(196, 160, 74, 0.08);
    border: 1px solid rgba(196, 160, 74, 0.15);
  }

  .form-error {
    color: #f87171;
    background: rgba(248, 113, 113, 0.08);
    border: 1px solid rgba(248, 113, 113, 0.15);
  }

  .form-success.show,
  .form-error.show {
    display: block;
  }

  @media (max-width: 768px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline src="/assets/js/contact-section.js" defer></script>
