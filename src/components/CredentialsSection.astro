---
interface Props { lang: 'en' | 'es'; }
const { lang } = Astro.props;

const en = {
  eyebrow: 'Background', title: 'Working style',
  workStyle: { items: [
    'Short discovery upfront so implementation scope is clear before code starts.',
    'Visible progress through GitHub, documented assumptions, and delivery notes.',
    'Pragmatic systems that can be run by humans without reading my mind.',
  ]},
};

const es = {
  eyebrow: 'Formación', title: 'Estilo de trabajo',
  workStyle: { items: [
    'Discovery corto al inicio para que el alcance esté claro antes de empezar el código.',
    'Progreso visible a través de GitHub, supuestos documentados y notas de entrega.',
    'Sistemas pragmáticos que cualquier operador puede ejecutar sin leer mi mente.',
  ]},
};

const c = lang === 'en' ? en : es;
---
<section class="section section--alt" id="credentials">
  <div class="container">
    <div class="section-header section-header--center">
      <span class="section-eyebrow reveal">{c.eyebrow}</span>
      <h2 class="section-title reveal">{c.title}</h2>
      <div class="divider reveal"></div>
    </div>
    <div class="cred-layout">
      <article class="card-glass reveal" role="region" aria-label={c.title}>
        <ul class="cred-list">
          {c.workStyle.items.map(item => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </div>
</section>

<style>
.cred-layout {
  max-width: 48rem;
}

.cred-list {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.cred-list li {
  font-size: 0.92rem;
  color: var(--clr-text-muted);
  line-height: 1.6;
  padding-left: 1rem;
  position: relative;
}

.cred-list li::before {
  content: '›';
  position: absolute;
  left: 0;
  color: var(--clr-accent);
  font-weight: 700;
}
</style>
