---
interface Props { lang: 'en' | 'es'; }
const { lang } = Astro.props;

const en = {
  eyebrow: 'Credentials', title: 'How I Work',
  workStyle: { title: 'Working style', items: ['Short discovery upfront so the implementation scope is clear before code starts.', 'Visible progress through GitHub, documented assumptions, and delivery notes.', 'Pragmatic systems that can be run by humans without reading my mind.'] },
  creds: [
    { name: 'Automate the Boring Stuff with Python', issuer: 'Udemy', year: 2022, href: 'https://www.udemy.com/certificate/UC-6516cd74-a25b-405d-962d-f3f6296db1c0/' },
    { name: 'Google Data Analytics', issuer: 'Coursera / Google', year: 2022, href: 'https://www.credly.com/badges/bfe5a0e2-b688-4300-be52-97d4ca8d6f6e/public_url' },
    { name: 'AWS Machine Learning Foundations', issuer: 'Udacity', year: 2022, href: 'https://graduation.udacity.com/confirm/KVWVKZFW' },
    { name: 'Data Science Orientation', issuer: 'Coursera / IBM', year: 2022, href: 'https://www.credly.com/badges/7b6d0fbb-81b4-4b90-a07a-ad49506619cc/linked_in_profile' },
    { name: 'EF SET English Certificate (C2)', issuer: 'EF', year: 2022, href: 'https://www.efset.org/cert/W91jYa' },
  ],
  credsTitle: 'Selected Credentials',
};

const es = {
  eyebrow: 'Credenciales', title: 'Cómo trabajo',
  workStyle: { title: 'Estilo de trabajo', items: ['Discovery corto al inicio para que el alcance esté claro antes de empezar el código.', 'Progreso visible a través de GitHub, supuestos documentados y notas de entrega.', 'Sistemas pragmáticos que cualquier operador puede ejecutar sin leer mi mente.'] },
  creds: [
    { name: 'Automate the Boring Stuff with Python', issuer: 'Udemy', year: 2022, href: 'https://www.udemy.com/certificate/UC-6516cd74-a25b-405d-962d-f3f6296db1c0/' },
    { name: 'Google Data Analytics', issuer: 'Coursera / Google', year: 2022, href: 'https://www.credly.com/badges/bfe5a0e2-b688-4300-be52-97d4ca8d6f6e/public_url' },
    { name: 'AWS Machine Learning Foundations', issuer: 'Udacity', year: 2022, href: 'https://graduation.udacity.com/confirm/KVWVKZFW' },
    { name: 'Data Science Orientation', issuer: 'Coursera / IBM', year: 2022, href: 'https://www.credly.com/badges/7b6d0fbb-81b4-4b90-a07a-ad49506619cc/linked_in_profile' },
    { name: 'EF SET Certificado de Inglés (C2)', issuer: 'EF', year: 2022, href: 'https://www.efset.org/cert/W91jYa' },
  ],
  credsTitle: 'Credenciales Seleccionadas',
};

const c = lang === 'en' ? en : es;
---
<section class="section section--alt" id="credentials">
  <div class="container">
    <div class="section-header section-header--center">
      <span class="section-eyebrow reveal">{c.eyebrow}</span>
      <h2 class="section-title reveal">{c.title}</h2>
      <div class="divider reveal"></div>
    </div>
    <div class="cred-layout">
      <article class="card-glass reveal">
        <h3 class="cred-card-title">{c.workStyle.title}</h3>
        <ul class="cred-list">
          {c.workStyle.items.map(item => <li>{item}</li>)}
        </ul>
      </article>
      <article class="card-glass reveal reveal-delay-1">
        <h3 class="cred-card-title">{c.credsTitle}</h3>
        <ul class="cred-badges">
          {c.creds.map(cr => (
            <li>
              <a class="cred-item" href={cr.href} target="_blank" rel="noopener noreferrer">
                <div class="cred-item__meta">
                  <span class="cred-item__name">{cr.name}</span>
                  <span class="cred-item__issuer">{cr.issuer} · {cr.year}</span>
                </div>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </a>
            </li>
          ))}
        </ul>
      </article>
    </div>
  </div>
</section>

<style>
.cred-layout { display: grid; grid-template-columns: 1fr 2fr; gap: 1.5rem; }
.cred-card-title {
  font-family: var(--ff-heading); font-size: 1rem; font-weight: 700;
  color: var(--clr-text); margin-bottom: 1rem;
}
.cred-list { display: flex; flex-direction: column; gap: 0.6rem; }
.cred-list li {
  font-size: 0.87rem; color: var(--clr-text-muted); line-height: 1.5;
  padding-left: 1rem; position: relative;
}
.cred-list li::before { content: '›'; position: absolute; left: 0; color: var(--clr-accent); font-weight: 700; }
.cred-badges { display: flex; flex-direction: column; gap: 0.5rem; }
.cred-item {
  display: flex; align-items: center; justify-content: space-between; gap: 1rem;
  padding: 0.6rem 0.75rem; border-radius: var(--radius-sm);
  border: 1px solid var(--clr-border); background: rgba(255,255,255,0.02);
  transition: border-color 150ms, background 150ms;
}
.cred-item:hover { border-color: var(--clr-border-glow); background: var(--clr-bg-card); }
.cred-item__meta { display: flex; flex-direction: column; gap: 2px; }
.cred-item__name { font-size: 0.83rem; font-weight: 600; color: var(--clr-text); }
.cred-item__issuer { font-size: 0.72rem; color: var(--clr-text-muted); }

@media (max-width: 768px) { .cred-layout { grid-template-columns: 1fr; } }
</style>
