---
interface Props {
  lang: 'en' | 'es';
}
const { lang } = Astro.props;

const en = {
  availability: 'Available for scoped automation projects',
  meta: 'Tooltician · Carlos Ortega Gonzalez',
  title: 'Python automation for reporting, ETL, and internal tools.',
  summary: 'I help teams replace fragile manual workflows with production-ready Python systems that are clear to operate, easy to hand off, and built to keep running.',
  support: 'Based in Santiago, Chile. I work in English and Spanish with teams across LATAM and U.S.-friendly time zones.',
  highlights: [
    'Reporting automation, ETL pipelines, and data collection workflows built for repeatable operation.',
    'Internal APIs and tooling delivered with CI, tests, and handoff documentation.',
    'Direct communication with technical and non-technical stakeholders in English or Spanish.',
  ],
  ctaPrimary: 'Start a project',
  ctaSecondary: 'See selected work',
  ctaPrimaryHref: '#contact-form',
  ctaSecondaryHref: '#portfolio',
  proofTitle: 'Public proof',
  proofItems: [
    { value: '3 live sites', label: 'publicly viewable today' },
    { value: '2 PyPI packages', label: 'installable now' },
    { value: 'CI + CodeQL', label: 'visible in public repos' },
    { value: 'EN / ES', label: 'client-ready delivery' },
  ],
  panelTitle: 'Engagement snapshot',
  panelIntro: 'Best fit when a team needs a fragile workflow stabilized without turning the project into a long, open-ended build.',
  panelItems: [
    {
      label: 'Typical scope',
      value: 'Reporting automation, ETL reliability, scraping workflows, and internal data tools.',
    },
    {
      label: 'Delivery style',
      value: 'Scoped implementation, direct stakeholder communication, and documentation built for handoff.',
    },
    {
      label: 'Timezone fit',
      value: 'Santiago-based, working in English and Spanish across LATAM and U.S.-friendly hours.',
    },
  ],
  noteTitle: 'Delivery defaults',
  noteBody: 'CI, tests, and operating notes are included when the workflow needs a reliable handoff.',
};

const es = {
  availability: 'Disponible para proyectos de automatización acotados',
  meta: 'Tooltician · Carlos Ortega González',
  title: 'Automatización Python para reportes, ETL y herramientas internas.',
  summary: 'Ayudo a los equipos a reemplazar flujos manuales frágiles por sistemas Python listos para producción: claros de operar, fáciles de traspasar y pensados para seguir funcionando.',
  support: 'Trabajo desde Santiago de Chile, en español e inglés, con equipos de LATAM y zonas horarias compatibles con EE.UU.',
  highlights: [
    'Automatización de reportes, pipelines ETL y flujos de captura de datos pensados para operación repetible.',
    'APIs internas y tooling entregados con CI, pruebas y documentación de traspaso.',
    'Comunicación directa con stakeholders técnicos y no técnicos en español o inglés.',
  ],
  ctaPrimary: 'Iniciar proyecto',
  ctaSecondary: 'Ver trabajo seleccionado',
  ctaPrimaryHref: '#contact-form',
  ctaSecondaryHref: '#portfolio',
  proofTitle: 'Prueba pública',
  proofItems: [
    { value: '3 sitios activos', label: 'visibles hoy' },
    { value: '2 paquetes PyPI', label: 'instalables ahora' },
    { value: 'CI + CodeQL', label: 'visible en repos públicos' },
    { value: 'ES / EN', label: 'entrega lista para clientes' },
  ],
  panelTitle: 'Panorama de trabajo',
  panelIntro: 'Encaja mejor cuando un equipo necesita estabilizar un flujo frágil sin convertir el proyecto en un desarrollo largo y abierto.',
  panelItems: [
    {
      label: 'Alcance típico',
      value: 'Automatización de reportes, confiabilidad ETL, scraping y herramientas internas de datos.',
    },
    {
      label: 'Forma de entrega',
      value: 'Implementación acotada, comunicación directa con stakeholders y documentación pensada para traspaso.',
    },
    {
      label: 'Cobertura horaria',
      value: 'Trabajo desde Santiago, en español e inglés, con equipos de LATAM y horarios compatibles con EE.UU.',
    },
  ],
  noteTitle: 'Entregables base',
  noteBody: 'CI, pruebas y notas operativas se incluyen cuando el flujo necesita un traspaso confiable.',
};

const c = lang === 'en' ? en : es;
---
<header class="hero" id="overview">
  <div class="hero__bg" aria-hidden="true"></div>
  <div class="container">
    <div class="hero__layout">
      <div class="hero__copy">
        <div class="hero__meta reveal">
          <span>{c.meta}</span>
          <span>{c.availability}</span>
        </div>
        <h1 class="hero__title reveal reveal-delay-1">{c.title}</h1>
        <p class="hero__summary reveal reveal-delay-2">{c.summary}</p>
        <p class="hero__support reveal reveal-delay-3">{c.support}</p>
        <div class="hero__actions reveal reveal-delay-3">
          <a class="btn btn-primary" href={c.ctaPrimaryHref}>{c.ctaPrimary}</a>
          <a class="btn btn-ghost" href={c.ctaSecondaryHref}>{c.ctaSecondary}</a>
        </div>
        <div class="hero__proofbar reveal reveal-delay-4" aria-label={c.proofTitle}>
          {c.proofItems.map(item => (
            <div class="hero__proofitem">
              <span class="hero__proofvalue">{item.value}</span>
              <span class="hero__prooflabel">{item.label}</span>
            </div>
          ))}
        </div>
        <ul class="hero__highlights reveal reveal-delay-4">
          {c.highlights.map(h => (
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              {h}
            </li>
          ))}
        </ul>
      </div>

      <div class="hero__aside reveal reveal-delay-2">
        <section class="hero__brief" aria-label={c.panelTitle}>
          <p class="hero__brief-kicker">{c.panelTitle}</p>
          <p class="hero__brief-intro">{c.panelIntro}</p>
          <dl class="hero__brief-list">
            {c.panelItems.map(item => (
              <div class="hero__brief-row">
                <dt>{item.label}</dt>
                <dd>{item.value}</dd>
              </div>
            ))}
          </dl>
        </section>
        <aside class="hero__note" aria-label={c.noteTitle}>
          <p class="hero__note-title">{c.noteTitle}</p>
          <p>{c.noteBody}</p>
        </aside>
      </div>
    </div>
  </div>
</header>

<style>
.hero {
  display: flex;
  align-items: center;
  padding-top: calc(var(--nav-height) + 3rem);
  padding-bottom: 4rem;
  position: relative;
  overflow: hidden;
  border-bottom: 1px solid var(--clr-border);
}
.hero__bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(180deg, rgba(15, 23, 41, 0.72) 0%, rgba(15, 23, 41, 0.32) 40%, rgba(7, 13, 26, 0) 100%);
}

.hero__layout {
  display: grid;
  grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
  gap: 3rem;
  align-items: start;
}
.hero__copy {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
}
.hero__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem 1rem;
  margin-bottom: 1rem;
  font-size: 0.84rem;
  color: var(--clr-text-muted);
}
.hero__title {
  font-family: var(--ff-heading);
  font-size: clamp(2.4rem, 5vw, 4.15rem);
  font-weight: 700;
  line-height: 1.04;
  letter-spacing: -0.03em;
  margin-bottom: 1rem;
  max-width: 11ch;
}
.hero__summary {
  font-size: clamp(1.02rem, 1.8vw, 1.16rem);
  color: var(--clr-text);
  line-height: 1.7;
  margin-bottom: 1rem;
  max-width: 60ch;
}
.hero__support {
  font-size: 0.96rem;
  color: var(--clr-text-muted);
  line-height: 1.65;
  margin-bottom: 1.5rem;
  max-width: 58ch;
}
.hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-bottom: 1.5rem;
}
.hero__actions .btn {
  border-radius: 10px;
  padding: 0.85rem 1.15rem;
}
.hero__actions .btn-ghost {
  background: rgba(255, 255, 255, 0.02);
}
.hero__proofbar {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 0.75rem;
  margin-bottom: 1.5rem;
}
.hero__proofitem {
  padding: 0.85rem 0.95rem;
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 14px;
  background: rgba(255, 255, 255, 0.03);
}
.hero__proofvalue {
  display: block;
  font-family: var(--ff-heading);
  font-size: 1rem;
  font-weight: 700;
  color: var(--clr-text);
  margin-bottom: 0.2rem;
}
.hero__prooflabel {
  display: block;
  font-size: 0.77rem;
  line-height: 1.45;
  color: var(--clr-text-muted);
}
.hero__highlights {
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
}
.hero__highlights li {
  display: flex;
  align-items: flex-start;
  gap: 0.65rem;
  font-size: 0.92rem;
  color: var(--clr-text-muted);
}
.hero__highlights li svg {
  flex-shrink: 0;
  margin-top: 2px;
  color: var(--clr-accent-2);
}

.hero__aside {
  position: relative;
  z-index: 1;
  display: grid;
  gap: 1rem;
  align-content: start;
}
.hero__brief {
  width: min(380px, 100%);
  margin-left: auto;
  padding: 1.35rem;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 18px;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.015)),
    rgba(15, 23, 41, 0.86);
  box-shadow: var(--shadow-card);
}
.hero__brief-kicker {
  font-size: 0.76rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--clr-accent-2);
  margin-bottom: 0.75rem;
}
.hero__brief-intro {
  font-size: 0.93rem;
  line-height: 1.65;
  color: var(--clr-text);
  margin-bottom: 1rem;
}
.hero__brief-list {
  display: grid;
  gap: 0.85rem;
}
.hero__brief-row {
  display: grid;
  gap: 0.28rem;
  padding-top: 0.85rem;
  border-top: 1px solid rgba(255, 255, 255, 0.08);
}
.hero__brief-row dt {
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  color: var(--clr-text);
}
.hero__brief-row dd {
  font-size: 0.88rem;
  line-height: 1.6;
  color: var(--clr-text-muted);
}
.hero__note {
  width: min(380px, 100%);
  margin-left: auto;
  padding: 1rem 1.15rem;
  border: 1px solid rgba(0, 212, 170, 0.18);
  border-radius: 14px;
  background: rgba(8, 18, 34, 0.78);
}
.hero__note-title {
  font-family: var(--ff-heading);
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--clr-text);
  margin-bottom: 0.35rem;
}
.hero__note p:last-child {
  font-size: 0.85rem;
  line-height: 1.6;
  color: var(--clr-text-muted);
}

@media (max-width: 1024px) {
  .hero {
    padding-top: calc(var(--nav-height) + 2rem);
  }
  .hero__layout {
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  .hero__copy {
    order: 1;
  }
  .hero__aside {
    order: 2;
  }
  .hero__brief,
  .hero__note {
    width: 100%;
    margin-left: 0;
  }
  .hero__proofbar {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 768px) {
  .hero {
    padding-top: calc(var(--nav-height) + 1.5rem);
    padding-bottom: 3rem;
  }
  .hero__title {
    max-width: none;
  }
  .hero__summary,
  .hero__support {
    max-width: none;
  }
  .hero__layout {
    gap: 2rem;
  }
}

@media (max-width: 640px) {
  .hero__meta {
    gap: 0.35rem 0.75rem;
    font-size: 0.8rem;
  }
  .hero__actions {
    flex-direction: column;
    align-items: stretch;
  }
  .hero__actions .btn {
    justify-content: center;
  }
  .hero__highlights li {
    font-size: 0.88rem;
  }
  .hero__proofbar {
    grid-template-columns: 1fr;
  }
  .hero__brief,
  .hero__note {
    padding-left: 1rem;
    padding-right: 1rem;
  }
}
</style>
