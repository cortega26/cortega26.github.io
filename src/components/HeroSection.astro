---
interface Props {
  lang: 'en' | 'es';
}
const { lang } = Astro.props;

const en = {
  availability: 'Scoped engagements for ops-heavy teams · EN / ES',
  meta: 'Tooltician — Carlos Ortega Gonzalez',
  title: 'Automation systems for reporting, ETL, and internal workflows — built to survive handoff.',
  summary: 'I help operations-heavy teams replace spreadsheet glue, brittle reporting, and manual review loops with Python systems that are easier to run, inspect, and hand off.',
  support: 'Best fit: reporting pipelines, ETL cleanup, scraping, internal tools, and stabilization work where the workflow already matters. Start with proof, then open a short brief.',
  routeTitle: 'Quick navigation',
  routes: [
    { label: 'Public proof', description: 'Signals before promises: packages, CI, stores, and live systems.', href: '#proof', },
    { label: 'Production work', description: 'Selected builds with visible outcomes and operator context.', href: '#portfolio', },
    { label: 'Project brief', description: 'Send the workflow, bottleneck, owner, and expected result.', href: '#contact-form', },
  ],
  highlightsTitle: 'What the work replaces',
  highlights: [
    'Replace recurring copy-paste and spreadsheet glue with repeatable runs.',
    'Make ETL, scraping, and reporting failures easier to detect before they hurt operations.',
    'Ship internal tools with docs and defaults that survive a real handoff.',
  ],
  ctaPrimary: 'Book free diagnostic call',
  ctaSecondary: 'Send a written brief',
  ctaPrimaryHref: 'https://calendly.com/ciortega26',
  ctaSecondaryHref: '#contact-form',
  ctaNoteLink: 'View work first',
  ctaNoteLinkHref: '#portfolio',
  featuredOutcome: {
    text: 'elrincondeebano.com',
    detail: 'live store · daily orders, 100+ SKUs, 0 outages in 14 months',
    href: 'https://elrincondeebano.com',
  },
  proofTitle: 'Visible proof',
  proofItems: [
    { value: 'elrincondeebano.com', label: 'live store · daily orders, 100+ SKUs, 0 outages in 14 months', href: 'https://elrincondeebano.com' },
    { value: 'monedario.cl', label: 'public finance product · updated 2026, no ads, no paywalls', href: 'https://monedario.cl' },
    { value: 'bankrecon on PyPI', label: 'fail-closed reconciliation · audit-grade logs', href: 'https://pypi.org/project/bankrecon/' },
    { value: 'EN / ES handoff', label: 'README + runbook, every engagement' },
  ],
  panelTitle: 'Operating notes',
  panelItems: [
    { label: 'Scope', value: 'Reporting automation, ETL reliability, scraping, internal data tools, and workflow stabilization.' },
    { label: 'Delivery', value: 'Scoped implementation, direct communication, explicit assumptions, and handoff-ready docs.' },
    { label: 'Availability', value: 'Open to new scoped engagements. Reply within 48 h with a direct fit or no. Free 15-min diagnostic call — you leave with clear scope direction, not a sales pitch.' },
    { label: 'Location', value: 'Santiago, working EN/ES across LATAM and U.S.-friendly hours.' },
  ],
  serviceLine: 'I also cover web technical hygiene for live sites: security headers, HTTPS, DNS, forms, and lightweight monitoring — no internal hire needed.',
  serviceHref: '/en/services/web-technical-hygiene/',
  serviceCta: 'View web technical hygiene',
};

const es = {
  availability: 'Proyectos acotados para equipos operativos · ES / EN',
  meta: 'Tooltician — Carlos Ortega González',
  title: 'Sistemas de automatización para reportes, ETL y flujos internos — construidos para sobrevivir al traspaso.',
  summary: 'Ayudo a equipos operativos a reemplazar hojas de cálculo frágiles, reportes que fallan en silencio y ciclos manuales de revisión por sistemas Python más fáciles de operar, auditar y traspasar.',
  support: 'Mejor encaje: pipelines de reportes, limpieza ETL, scraping, herramientas internas y trabajo de estabilización donde el flujo ya importa. Parte por la evidencia y luego abre un brief corto.',
  serviceLine: 'También cubro mantención técnica web para sitios ya publicados: headers, HTTPS, DNS, formularios y monitoreo liviano sin necesidad de sumar un perfil interno.',
  serviceHref: '/es/servicios/higiene-tecnica-web/',
  serviceCta: 'Ver higiene técnica web',
  routeTitle: 'Navegación rápida',
  routes: [
    { label: 'Evidencia pública', description: 'Señales antes que promesas: paquetes, CI, stores y sistemas activos.', href: '#proof', },
    { label: 'Trabajo en producción', description: 'Builds con resultados visibles y contexto operativo.', href: '#portfolio', },
    { label: 'Brief del proyecto', description: 'Envía flujo, cuello de botella, responsable y resultado esperado.', href: '#contact-form', },
  ],
  highlightsTitle: 'Qué reemplaza el trabajo',
  highlights: [
    'Reemplazo copia-pega recurrente y hojas de cálculo frágiles por ejecuciones repetibles.',
    'Vuelvo más visibles las fallas de ETL, scraping y reporting antes de que golpeen la operación.',
    'Entrego herramientas internas con docs y defaults que sobreviven a un traspaso real.',
  ],
  ctaPrimary: 'Agendar llamada de diagnóstico gratis',
  ctaSecondary: 'Enviar un brief escrito',
  ctaPrimaryHref: 'https://calendly.com/ciortega26',
  ctaSecondaryHref: '#contact-form',
  ctaNoteLink: 'Ver el trabajo primero',
  ctaNoteLinkHref: '#portfolio',
  featuredOutcome: {
    text: 'elrincondeebano.com',
    detail: 'tienda activa · pedidos diarios, 100+ SKUs, 0 caídas en 14 meses',
    href: 'https://elrincondeebano.com',
  },
  proofTitle: 'Prueba visible',
  proofItems: [
    { value: 'elrincondeebano.com', label: 'tienda activa · pedidos diarios, 100+ SKUs, 0 caídas en 14 meses', href: 'https://elrincondeebano.com' },
    { value: 'monedario.cl', label: 'producto público de finanzas · actualizado 2026, sin publicidad ni paywalls', href: 'https://monedario.cl' },
    { value: 'bankrecon en PyPI', label: 'conciliación fail-closed · logs de auditoría', href: 'https://pypi.org/project/bankrecon/' },
    { value: 'Traspaso ES / EN', label: 'README + runbook, en cada proyecto' },
  ],
  panelTitle: 'Notas operativas',
  panelItems: [
    { label: 'Alcance', value: 'Automatización de reportes, confiabilidad ETL, scraping, herramientas internas de datos y estabilización de flujos.' },
    { label: 'Entrega', value: 'Implementación acotada, comunicación directa, supuestos explícitos y docs para traspaso.' },
    { label: 'Disponibilidad', value: 'Disponible para nuevos proyectos acotados. Respuesta en 48 h con encaje directo o no. Llamada de diagnóstico gratis de 15 min — terminas la llamada con dirección de alcance clara, sin pitch de ventas.' },
    { label: 'Ubicación', value: 'Santiago, trabajo ES/EN con LATAM y horarios compatibles con EE.UU.' },
  ],
};

const c = lang === 'en' ? en : es;
---
<header class="hero" id="overview">
  <div class="container">
    <div class="hero__content">
      <div class="hero__main">
        <div class="hero__meta reveal">
          <span>{c.meta}</span>
          <span class="hero__meta-divider" aria-hidden="true">·</span>
          <span>{c.availability}</span>
        </div>
        <h1 class="hero__title reveal reveal-delay-1">{c.title}</h1>
        <a class="hero__featured-outcome reveal reveal-delay-1" href={c.featuredOutcome.href} target="_blank" rel="noopener noreferrer">
          <span class="hero__featured-name">{c.featuredOutcome.text}</span>
          <span class="hero__featured-detail">{c.featuredOutcome.detail}</span>
        </a>
        <p class="hero__summary reveal reveal-delay-2">{c.summary}</p>
        <p class="hero__support reveal reveal-delay-2">{c.support}</p>
        {c.serviceLine && (
          <p class="hero__service-note reveal reveal-delay-2">
            <span>{c.serviceLine}</span>
            <a href={c.serviceHref}>{c.serviceCta}</a>
          </p>
        )}
        <div class="hero__actions reveal reveal-delay-2">
          <a class="btn btn-primary" href={c.ctaPrimaryHref} target="_blank" rel="noopener noreferrer">{c.ctaPrimary}</a>
          <a class="btn btn-ghost" href={c.ctaSecondaryHref}>{c.ctaSecondary}</a>
        </div>
        <p class="hero__cta-note reveal reveal-delay-2">
          <a href={c.ctaNoteLinkHref}>{c.ctaNoteLink} →</a>
        </p>
      </div>

    </div>

    <div class="hero__board reveal reveal-delay-2">
      <div class="hero__board-col">
        <p class="hero__board-heading">{c.highlightsTitle}</p>
        <ul class="hero__highlights">
          {c.highlights.map(h => (
            <li>{h}</li>
          ))}
        </ul>
      </div>
      <div class="hero__board-col">
        <p class="hero__board-heading">{c.panelTitle}</p>
        <dl class="hero__brief-list">
          {c.panelItems.map(item => (
            <div class="hero__brief-row">
              <dt>{item.label}</dt>
              <dd>{item.value}</dd>
            </div>
          ))}
        </dl>
      </div>
      <div class="hero__board-col">
        <p class="hero__board-heading">{c.proofTitle}</p>
        <div class="hero__proof-list">
          {c.proofItems.map(item => (
            item.href ? (
              <a class="hero__proof-item hero__proof-item--link" href={item.href} target="_blank" rel="noopener noreferrer">
                <span class="hero__proof-value">{item.value}</span>
                <span class="hero__proof-label">{item.label}</span>
              </a>
            ) : (
              <div class="hero__proof-item">
                <span class="hero__proof-value">{item.value}</span>
                <span class="hero__proof-label">{item.label}</span>
              </div>
            )
          ))}
        </div>
      </div>
    </div>

    <aside class="hero__summary-panel reveal" aria-label={c.routeTitle}>
      <div class="hero__routes">
        {c.routes.map((route, i) => (
          <a class="hero__route-link" href={route.href}>
            <span class="hero__route-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="hero__route-body">
              <span class="hero__route-label">{route.label}</span>
              <span class="hero__route-desc">{route.description}</span>
            </span>
            <span class="hero__route-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </aside>
  </div>
</header>

<style>
.hero {
  padding-top: calc(var(--nav-height) + 5rem);
  padding-bottom: 4rem;
  border-bottom: 1px solid var(--clr-border);
  position: relative;
}

.hero__content {
  display: block;
  max-width: 70ch;
}

.hero__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem 0.6rem;
  margin-bottom: 1.25rem;
  font-family: var(--ff-label);
  font-size: 0.7rem;
  letter-spacing: 0.04em;
  color: var(--clr-text-faint);
  align-items: center;
}

.hero__meta-divider {
  opacity: 0.35;
}

.hero__title {
  font-family: var(--ff-heading);
  font-size: clamp(2.6rem, 5vw, 4.5rem);
  font-weight: 700;
  line-height: 0.92;
  letter-spacing: -0.04em;
  margin-bottom: 1rem;
  text-wrap: balance;
}

.hero__featured-outcome {
  display: inline-flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 0.3rem 0.65rem;
  margin-bottom: 1.25rem;
  padding: 0.45rem 0.85rem;
  border: 1px solid rgba(196, 160, 74, 0.2);
  border-radius: var(--radius-sm);
  background: rgba(196, 160, 74, 0.06);
  text-decoration: none;
  transition: border-color 150ms, background 150ms;
}

.hero__featured-outcome:hover {
  border-color: rgba(196, 160, 74, 0.4);
  background: rgba(196, 160, 74, 0.1);
}

.hero__featured-name {
  font-family: var(--ff-label);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  color: var(--clr-accent);
  text-transform: uppercase;
}

.hero__featured-detail {
  font-size: 0.82rem;
  color: var(--clr-text-muted);
  line-height: 1.4;
}

.hero__summary {
  font-size: clamp(1rem, 1.4vw, 1.12rem);
  color: var(--clr-text);
  line-height: 1.7;
  margin-bottom: 1rem;
  max-width: 60ch;
}

.hero__support {
  font-size: 0.92rem;
  color: var(--clr-text-muted);
  line-height: 1.65;
  margin-bottom: 1rem;
  max-width: 52ch;
}

.hero__service-note {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem 0.8rem;
  align-items: center;
  margin-bottom: 1.75rem;
  max-width: 56ch;
  padding: 0.8rem 0.95rem;
  border: 1px solid rgba(196, 160, 74, 0.18);
  border-radius: var(--radius-sm);
  background: rgba(196, 160, 74, 0.05);
  font-size: 0.84rem;
  line-height: 1.65;
  color: var(--clr-text-muted);
}

.hero__service-note a {
  color: var(--clr-accent);
  font-family: var(--ff-label);
  font-size: 0.72rem;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.hero__service-note a:hover {
  color: var(--clr-text);
}

.hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-bottom: 0.6rem;
}

.hero__cta-note {
  font-size: 0.78rem;
  color: var(--clr-text-faint);
  margin-bottom: 1.75rem;
}

.hero__cta-note a {
  color: var(--clr-accent);
  font-weight: 600;
}

.hero__cta-note a:hover {
  color: var(--clr-accent-hover);
}

/* Routes panel — below the fold */
.hero__summary-panel {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  border: 1px solid var(--clr-border);
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.02);
  overflow: hidden;
  margin-top: 1.5rem;
}

.hero__routes {
  display: contents;
}

.hero__route-link {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 0.75rem;
  align-items: center;
  padding: 0.9rem 1rem;
  border-right: 1px solid var(--clr-border);
  transition: background var(--dur-fast);
}

.hero__route-link:last-child {
  border-right: none;
}

.hero__route-link:hover {
  background: rgba(255, 255, 255, 0.04);
}

.hero__route-num {
  font-family: var(--ff-label);
  font-size: 0.65rem;
  color: var(--clr-accent);
  opacity: 0.6;
}

.hero__route-body {
  display: grid;
  gap: 0.1rem;
}

.hero__route-label {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--clr-text);
  transition: color var(--dur-fast);
}

.hero__route-link:hover .hero__route-label {
  color: var(--clr-accent);
}

.hero__route-desc {
  font-size: 0.8rem;
  line-height: 1.5;
  color: var(--clr-text-muted);
}

.hero__route-arrow {
  font-family: var(--ff-label);
  font-size: 0.85rem;
  color: var(--clr-text-faint);
  opacity: 0;
  transform: translateX(-4px);
  transition: opacity var(--dur-fast), transform var(--dur-fast);
}

.hero__route-link:hover .hero__route-arrow {
  opacity: 1;
  transform: translateX(0);
  color: var(--clr-accent);
}

/* Board */
.hero__board {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 3rem;
  border: 1px solid var(--clr-border);
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.02);
  overflow: hidden;
}

.hero__board-col {
  padding: 1.25rem 1rem 1.5rem;
}

.hero__board-col:not(:last-child) {
  border-right: 1px solid var(--clr-border);
}

.hero__board-heading {
  font-family: var(--ff-label);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--clr-text-faint);
  margin-bottom: 1rem;
}

.hero__highlights {
  display: grid;
  gap: 0.85rem;
}

.hero__highlights li {
  position: relative;
  padding-left: 0.85rem;
  font-size: 0.87rem;
  line-height: 1.6;
  color: var(--clr-text-muted);
}

.hero__highlights li::before {
  content: '';
  position: absolute;
  top: 0.7em;
  left: 0;
  width: 4px;
  height: 4px;
  background: var(--clr-accent);
  opacity: 0.6;
}

.hero__brief-list {
  display: grid;
  gap: 0.75rem;
}

.hero__brief-row {
  display: grid;
  gap: 0.15rem;
  padding-top: 0.65rem;
  border-top: 1px solid var(--clr-border);
}

.hero__brief-row:first-child {
  padding-top: 0;
  border-top: 0;
}

.hero__brief-row dt {
  font-family: var(--ff-label);
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--clr-accent);
  opacity: 0.8;
}

.hero__brief-row dd {
  font-size: 0.85rem;
  line-height: 1.55;
  color: var(--clr-text-muted);
}

.hero__proof-list {
  display: grid;
  gap: 0.65rem;
}

.hero__proof-item {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 1rem;
  padding-bottom: 0.6rem;
  border-bottom: 1px solid var(--clr-border);
  text-decoration: none;
}

.hero__proof-item--link:hover .hero__proof-value {
  color: var(--clr-accent);
}

.hero__proof-value {
  font-family: var(--ff-label);
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--clr-text);
  letter-spacing: 0.04em;
  text-transform: uppercase;
  white-space: nowrap;
}

.hero__proof-label {
  font-size: 0.82rem;
  line-height: 1.5;
  color: var(--clr-text-muted);
  text-align: right;
}

@media (max-width: 1024px) {
  .hero {
    padding-top: calc(var(--nav-height) + 3rem);
  }
  .hero__board {
    grid-template-columns: 1fr;
  }
  .hero__board-col:not(:last-child) {
    border-right: 0;
    border-bottom: 1px solid var(--clr-border);
  }
  .hero__summary-panel {
    grid-template-columns: 1fr;
  }
  .hero__route-link {
    border-right: 0;
    border-bottom: 1px solid var(--clr-border);
  }
  .hero__route-link:last-child {
    border-bottom: none;
  }
}

@media (max-width: 768px) {
  .hero {
    padding-top: calc(var(--nav-height) + 2rem);
    padding-bottom: 3rem;
  }
  .hero__board-col {
    padding-inline: 0;
  }
  .hero__content {
    max-width: 100%;
  }
}

@media (max-width: 640px) {
  .hero__actions {
    flex-direction: column;
    align-items: stretch;
  }
  .hero__actions .btn {
    justify-content: center;
  }
  .hero__proof-item {
    flex-direction: column;
    align-items: flex-start;
  }
  .hero__proof-label {
    text-align: left;
  }
  .hero__featured-outcome {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
}
</style>
