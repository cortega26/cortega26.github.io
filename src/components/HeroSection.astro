---
interface Props {
  lang: 'en' | 'es';
}
const { lang } = Astro.props;

const en = {
  availability: 'Scoped engagements · EN / ES',
  meta: 'Tooltician — Carlos Ortega Gonzalez',
  title: 'Automation systems for reporting, ETL, and internal workflows — built to survive handoff.',
  summary: 'I build Python automation and delivery systems that remove brittle manual steps, expose the right checks, and leave teams with something they can actually operate.',
  support: 'The fastest way to use this site is to inspect proof, browse real work, and then open a short brief.',
  routeTitle: 'Quick navigation',
  routes: [
    { label: 'Public proof', description: 'Packages, CI signals, and live systems.', href: '#proof', },
    { label: 'Production work', description: 'Selected builds with visible outcomes.', href: '#portfolio', },
    { label: 'Project brief', description: 'Send the workflow and the expected outcome.', href: '#contact-form', },
  ],
  highlightsTitle: 'Core work',
  highlights: [
    'Reporting automation and structured data delivery.',
    'ETL reliability, scraping, and repeatable data collection.',
    'Internal tooling that improves operator comprehension.',
  ],
  ctaPrimary: 'Open brief',
  ctaSecondary: 'View work',
  ctaPrimaryHref: '#contact-form',
  ctaSecondaryHref: '#portfolio',
  proofTitle: 'Delivery signals',
  proofItems: [
    { value: '3 live sites', label: 'publicly viewable' },
    { value: '2 PyPI packages', label: 'installable now' },
    { value: 'CI + CodeQL', label: 'visible in public repos' },
    { value: 'EN / ES', label: 'delivery-ready communication' },
  ],
  panelTitle: 'Operating notes',
  panelItems: [
    { label: 'Scope', value: 'Reporting automation, ETL, scraping, and internal data tools.' },
    { label: 'Delivery', value: 'Scoped implementation, direct communication, handoff-ready docs.' },
    { label: 'Location', value: 'Santiago, working EN/ES across LATAM and U.S.-friendly hours.' },
  ],
};

const es = {
  availability: 'Proyectos acotados · ES / EN',
  meta: 'Tooltician — Carlos Ortega González',
  title: 'Sistemas de automatización para reportes, ETL y flujos internos — construidos para sobrevivir al traspaso.',
  summary: 'Construyo sistemas Python y flujos de entrega que reemplazan pasos manuales frágiles, exponen los controles correctos y dejan algo que el equipo puede operar.',
  support: 'La forma más rápida de usar este sitio es revisar evidencia pública, ver trabajo real y luego enviar un brief corto.',
  routeTitle: 'Navegación rápida',
  routes: [
    { label: 'Evidencia pública', description: 'Paquetes, CI y sistemas activos.', href: '#proof', },
    { label: 'Trabajo en producción', description: 'Builds con resultados visibles.', href: '#portfolio', },
    { label: 'Brief del proyecto', description: 'Envía el flujo y el resultado esperado.', href: '#contact-form', },
  ],
  highlightsTitle: 'Trabajo base',
  highlights: [
    'Automatización de reportes y entrega estructurada de datos.',
    'Confiabilidad ETL, scraping y recolección de datos repetible.',
    'Herramientas internas que mejoran la comprensión del operador.',
  ],
  ctaPrimary: 'Abrir brief',
  ctaSecondary: 'Ver trabajo',
  ctaPrimaryHref: '#contact-form',
  ctaSecondaryHref: '#portfolio',
  proofTitle: 'Señales de entrega',
  proofItems: [
    { value: '3 sitios activos', label: 'visibles hoy' },
    { value: '2 paquetes PyPI', label: 'instalables ahora' },
    { value: 'CI + CodeQL', label: 'visible en repos públicos' },
    { value: 'ES / EN', label: 'comunicación bilingüe' },
  ],
  panelTitle: 'Notas operativas',
  panelItems: [
    { label: 'Alcance', value: 'Automación de reportes, ETL, scraping y herramientas internas de datos.' },
    { label: 'Entrega', value: 'Implementación acotada, comunicación directa, docs para traspaso.' },
    { label: 'Ubicación', value: 'Santiago, trabajo ES/EN con LATAM y horarios compatibles con EE.UU.' },
  ],
};

const c = lang === 'en' ? en : es;
---
<header class="hero" id="overview">
  <div class="container">
    <div class="hero__content">
      <div class="hero__main">
        <div class="hero__meta reveal">
          <span>{c.meta}</span>
          <span class="hero__meta-divider" aria-hidden="true">·</span>
          <span>{c.availability}</span>
        </div>
        <h1 class="hero__title reveal reveal-delay-1">{c.title}</h1>
        <p class="hero__summary reveal reveal-delay-2">{c.summary}</p>
        <p class="hero__support reveal reveal-delay-3">{c.support}</p>
        <div class="hero__actions reveal reveal-delay-3">
          <a class="btn btn-primary" href={c.ctaPrimaryHref}>{c.ctaPrimary}</a>
          <a class="btn btn-ghost" href={c.ctaSecondaryHref}>{c.ctaSecondary}</a>
        </div>
      </div>

      <aside class="hero__summary-panel reveal reveal-delay-2" aria-label={c.routeTitle}>
        <div class="hero__routes">
          {c.routes.map((route, i) => (
            <a class="hero__route-link" href={route.href}>
              <span class="hero__route-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="hero__route-body">
                <span class="hero__route-label">{route.label}</span>
                <span class="hero__route-desc">{route.description}</span>
              </span>
              <span class="hero__route-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </aside>
    </div>

    <div class="hero__board reveal reveal-delay-4">
      <div class="hero__board-col">
        <p class="hero__board-heading">{c.highlightsTitle}</p>
        <ul class="hero__highlights">
          {c.highlights.map(h => (
            <li>{h}</li>
          ))}
        </ul>
      </div>
      <div class="hero__board-col">
        <p class="hero__board-heading">{c.panelTitle}</p>
        <dl class="hero__brief-list">
          {c.panelItems.map(item => (
            <div class="hero__brief-row">
              <dt>{item.label}</dt>
              <dd>{item.value}</dd>
            </div>
          ))}
        </dl>
      </div>
      <div class="hero__board-col">
        <p class="hero__board-heading">{c.proofTitle}</p>
        <div class="hero__proof-list">
          {c.proofItems.map(item => (
            <div class="hero__proof-item">
              <span class="hero__proof-value">{item.value}</span>
              <span class="hero__proof-label">{item.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</header>

<style>
.hero {
  padding-top: calc(var(--nav-height) + 5rem);
  padding-bottom: 4rem;
  border-bottom: 1px solid var(--clr-border);
  position: relative;
}

.hero__content {
  display: grid;
  grid-template-columns: minmax(0, 1.35fr) minmax(260px, 0.65fr);
  gap: 2.5rem;
  align-items: start;
}

.hero__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem 0.6rem;
  margin-bottom: 1.25rem;
  font-family: var(--ff-label);
  font-size: 0.7rem;
  letter-spacing: 0.04em;
  color: var(--clr-text-faint);
  align-items: center;
}

.hero__meta-divider {
  opacity: 0.35;
}

.hero__title {
  font-family: var(--ff-heading);
  font-size: clamp(2.6rem, 5vw, 4.5rem);
  font-weight: 700;
  line-height: 0.92;
  letter-spacing: -0.04em;
  margin-bottom: 1.25rem;
  text-wrap: balance;
}

.hero__summary {
  font-size: clamp(1rem, 1.4vw, 1.12rem);
  color: var(--clr-text);
  line-height: 1.7;
  margin-bottom: 1rem;
  max-width: 60ch;
}

.hero__support {
  font-size: 0.92rem;
  color: var(--clr-text-muted);
  line-height: 1.65;
  margin-bottom: 1.75rem;
  max-width: 52ch;
}

.hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
}

/* Routes sidebar */
.hero__summary-panel {
  border: 1px solid var(--clr-border);
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.02);
  overflow: hidden;
}

.hero__route-link {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 0.75rem;
  align-items: center;
  padding: 0.9rem 1rem;
  border-bottom: 1px solid var(--clr-border);
  transition: background var(--dur-fast);
}

.hero__route-link:last-child {
  border-bottom: none;
}

.hero__route-link:hover {
  background: rgba(255, 255, 255, 0.04);
}

.hero__route-num {
  font-family: var(--ff-label);
  font-size: 0.65rem;
  color: var(--clr-accent);
  opacity: 0.6;
}

.hero__route-body {
  display: grid;
  gap: 0.1rem;
}

.hero__route-label {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--clr-text);
  transition: color var(--dur-fast);
}

.hero__route-link:hover .hero__route-label {
  color: var(--clr-accent);
}

.hero__route-desc {
  font-size: 0.8rem;
  line-height: 1.5;
  color: var(--clr-text-muted);
}

.hero__route-arrow {
  font-family: var(--ff-label);
  font-size: 0.85rem;
  color: var(--clr-text-faint);
  opacity: 0;
  transform: translateX(-4px);
  transition: opacity var(--dur-fast), transform var(--dur-fast);
}

.hero__route-link:hover .hero__route-arrow {
  opacity: 1;
  transform: translateX(0);
  color: var(--clr-accent);
}

/* Board */
.hero__board {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 3rem;
  border: 1px solid var(--clr-border);
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.02);
  overflow: hidden;
}

.hero__board-col {
  padding: 1.25rem 1rem 1.5rem;
}

.hero__board-col:not(:last-child) {
  border-right: 1px solid var(--clr-border);
}

.hero__board-heading {
  font-family: var(--ff-label);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--clr-text-faint);
  margin-bottom: 1rem;
}

.hero__highlights {
  display: grid;
  gap: 0.85rem;
}

.hero__highlights li {
  position: relative;
  padding-left: 0.85rem;
  font-size: 0.87rem;
  line-height: 1.6;
  color: var(--clr-text-muted);
}

.hero__highlights li::before {
  content: '';
  position: absolute;
  top: 0.7em;
  left: 0;
  width: 4px;
  height: 4px;
  background: var(--clr-accent);
  opacity: 0.6;
}

.hero__brief-list {
  display: grid;
  gap: 0.75rem;
}

.hero__brief-row {
  display: grid;
  gap: 0.15rem;
  padding-top: 0.65rem;
  border-top: 1px solid var(--clr-border);
}

.hero__brief-row:first-child {
  padding-top: 0;
  border-top: 0;
}

.hero__brief-row dt {
  font-family: var(--ff-label);
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--clr-accent);
  opacity: 0.8;
}

.hero__brief-row dd {
  font-size: 0.85rem;
  line-height: 1.55;
  color: var(--clr-text-muted);
}

.hero__proof-list {
  display: grid;
  gap: 0.65rem;
}

.hero__proof-item {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 1rem;
  padding-bottom: 0.6rem;
  border-bottom: 1px solid var(--clr-border);
}

.hero__proof-value {
  font-family: var(--ff-label);
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--clr-text);
  letter-spacing: 0.04em;
  text-transform: uppercase;
  white-space: nowrap;
}

.hero__proof-label {
  font-size: 0.82rem;
  line-height: 1.5;
  color: var(--clr-text-muted);
  text-align: right;
}

@media (max-width: 1024px) {
  .hero {
    padding-top: calc(var(--nav-height) + 3rem);
  }
  .hero__content {
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  .hero__board {
    grid-template-columns: 1fr;
  }
  .hero__board-col:not(:last-child) {
    border-right: 0;
    border-bottom: 1px solid var(--clr-border);
  }
}

@media (max-width: 768px) {
  .hero {
    padding-top: calc(var(--nav-height) + 2rem);
    padding-bottom: 3rem;
  }
  .hero__board-col {
    padding-inline: 0;
  }
}

@media (max-width: 640px) {
  .hero__actions {
    flex-direction: column;
    align-items: stretch;
  }
  .hero__actions .btn {
    justify-content: center;
  }
  .hero__proof-item {
    flex-direction: column;
    align-items: flex-start;
  }
  .hero__proof-label {
    text-align: left;
  }
}
</style>
