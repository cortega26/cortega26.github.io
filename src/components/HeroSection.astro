---
interface Props {
  lang: 'en' | 'es';
}
const { lang } = Astro.props;

const en = {
  availability: 'Available for scoped automation projects',
  meta: 'Tooltician · Carlos Ortega Gonzalez',
  title: 'Python automation for reporting, ETL, and internal tools.',
  summary: 'I help teams replace fragile manual workflows with production-ready Python systems that are clear to operate, easy to hand off, and built to keep running.',
  support: 'Based in Santiago, Chile. I work in English and Spanish with teams across LATAM and U.S.-friendly time zones.',
  highlights: [
    'Reporting automation, ETL pipelines, and data collection workflows built for repeatable operation.',
    'Internal APIs and tooling delivered with CI, tests, and handoff documentation.',
    'Direct communication with technical and non-technical stakeholders in English or Spanish.',
  ],
  ctaPrimary: 'Start a project',
  ctaSecondary: 'See selected work',
  ctaPrimaryHref: 'mailto:carlos@tooltician.com?subject=Project%20Inquiry',
  ctaSecondaryHref: '#portfolio',
  photoAlt: 'Professional portrait of Carlos Ortega Gonzalez',
  card1Title: 'Best-fit engagements',
  card1Body: 'Short, scoped consulting for reporting automation, ETL reliability, scraping workflows, and internal data tools.',
  card2Title: 'What clients get',
  card2Body: 'Implementation, documentation, and a system your team can keep operating without vendor lock-in.',
};

const es = {
  availability: 'Disponible para proyectos de automatización acotados',
  meta: 'Tooltician · Carlos Ortega González',
  title: 'Automatización Python para reportes, ETL y herramientas internas.',
  summary: 'Ayudo a los equipos a reemplazar flujos manuales frágiles por sistemas Python listos para producción: claros de operar, fáciles de traspasar y pensados para seguir funcionando.',
  support: 'Trabajo desde Santiago de Chile, en español e inglés, con equipos de LATAM y zonas horarias compatibles con EE.UU.',
  highlights: [
    'Automatización de reportes, pipelines ETL y flujos de captura de datos pensados para operación repetible.',
    'APIs internas y tooling entregados con CI, pruebas y documentación de traspaso.',
    'Comunicación directa con stakeholders técnicos y no técnicos en español o inglés.',
  ],
  ctaPrimary: 'Iniciar proyecto',
  ctaSecondary: 'Ver trabajo seleccionado',
  ctaPrimaryHref: 'mailto:carlos@tooltician.com?subject=Consulta%20de%20Proyecto',
  ctaSecondaryHref: '#portfolio',
  photoAlt: 'Retrato profesional de Carlos Ortega González',
  card1Title: 'Proyectos ideales',
  card1Body: 'Consultoría breve y acotada para automatización de reportes, confiabilidad ETL, scraping y herramientas internas de datos.',
  card2Title: 'Qué recibe tu equipo',
  card2Body: 'Implementación, documentación y un sistema que tu equipo pueda seguir operando sin dependencia del proveedor.',
};

const c = lang === 'en' ? en : es;
---
<header class="hero" id="overview">
  <div class="hero__bg" aria-hidden="true"></div>
  <div class="container">
    <div class="hero__layout">
      <div class="hero__copy">
        <div class="hero__meta reveal">
          <span>{c.meta}</span>
          <span>{c.availability}</span>
        </div>
        <h1 class="hero__title reveal reveal-delay-1">{c.title}</h1>
        <p class="hero__summary reveal reveal-delay-2">{c.summary}</p>
        <p class="hero__support reveal reveal-delay-3">{c.support}</p>
        <div class="hero__actions reveal reveal-delay-3">
          <a class="btn btn-primary" href={c.ctaPrimaryHref}>{c.ctaPrimary}</a>
          <a class="btn btn-ghost" href={c.ctaSecondaryHref}>{c.ctaSecondary}</a>
        </div>
        <ul class="hero__highlights reveal reveal-delay-4">
          {c.highlights.map(h => (
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              {h}
            </li>
          ))}
        </ul>
      </div>

      <div class="hero__aside reveal reveal-delay-2">
        <figure class="hero__figure">
          <img
            class="hero__photo"
            src="/assets/images/profile-photo.webp"
            alt={c.photoAlt}
            width="380" height="380"
            loading="eager"
            decoding="async"
            onerror="this.src='/assets/images/profile-photo.png'"
          />
        </figure>
        <div class="hero__cards">
          <article class="hero__card">
            <h3>{c.card1Title}</h3>
            <p>{c.card1Body}</p>
          </article>
          <article class="hero__card">
            <h3>{c.card2Title}</h3>
            <p>{c.card2Body}</p>
          </article>
        </div>
      </div>
    </div>
  </div>
</header>

<style>
.hero {
  display: flex;
  align-items: center;
  padding-top: calc(var(--nav-height) + 3rem);
  padding-bottom: 4rem;
  position: relative;
  overflow: hidden;
  border-bottom: 1px solid var(--clr-border);
}
.hero__bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(180deg, rgba(15, 23, 41, 0.72) 0%, rgba(15, 23, 41, 0.32) 40%, rgba(7, 13, 26, 0) 100%);
}

.hero__layout {
  display: grid;
  grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
  gap: 3rem;
  align-items: start;
}
.hero__copy {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
}
.hero__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem 1rem;
  margin-bottom: 1rem;
  font-size: 0.84rem;
  color: var(--clr-text-muted);
}
.hero__title {
  font-family: var(--ff-heading);
  font-size: clamp(2.4rem, 5vw, 4.15rem);
  font-weight: 700;
  line-height: 1.04;
  letter-spacing: -0.03em;
  margin-bottom: 1rem;
  max-width: 11ch;
}
.hero__summary {
  font-size: clamp(1.02rem, 1.8vw, 1.16rem);
  color: var(--clr-text);
  line-height: 1.7;
  margin-bottom: 1rem;
  max-width: 60ch;
}
.hero__support {
  font-size: 0.96rem;
  color: var(--clr-text-muted);
  line-height: 1.65;
  margin-bottom: 1.5rem;
  max-width: 58ch;
}
.hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-bottom: 1.5rem;
}
.hero__actions .btn {
  border-radius: 10px;
  padding: 0.85rem 1.15rem;
}
.hero__actions .btn-ghost {
  background: rgba(255, 255, 255, 0.02);
}
.hero__highlights {
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
}
.hero__highlights li {
  display: flex;
  align-items: flex-start;
  gap: 0.65rem;
  font-size: 0.92rem;
  color: var(--clr-text-muted);
}
.hero__highlights li svg {
  flex-shrink: 0;
  margin-top: 2px;
  color: var(--clr-accent-2);
}

.hero__aside {
  position: relative;
  z-index: 1;
  display: grid;
  gap: 0.9rem;
}
.hero__figure {
  width: min(340px, 100%);
  margin: 0 0 0 auto;
  padding: 0.75rem;
  border: 1px solid var(--clr-border);
  border-radius: 14px;
  background: rgba(15, 23, 41, 0.82);
}
.hero__photo {
  display: block;
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 10px;
  object-fit: cover;
  background: var(--clr-surface);
}
.hero__cards {
  display: grid;
  gap: 0.75rem;
}
.hero__card h3 {
  font-family: var(--ff-heading);
  font-size: 0.92rem;
  font-weight: 600;
  margin-bottom: 0.35rem;
  color: var(--clr-text);
}
.hero__card p {
  font-size: 0.86rem;
  color: var(--clr-text-muted);
  line-height: 1.55;
}
.hero__card {
  padding: 1rem 1.15rem;
  border: 1px solid var(--clr-border);
  border-radius: 12px;
  background: rgba(15, 23, 41, 0.72);
}

@media (max-width: 1024px) {
  .hero {
    padding-top: calc(var(--nav-height) + 2rem);
  }
  .hero__layout {
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  .hero__copy {
    order: 1;
  }
  .hero__aside {
    order: 2;
  }
  .hero__figure {
    width: min(300px, 100%);
    margin: 0 auto;
  }
}

@media (max-width: 768px) {
  .hero {
    padding-top: calc(var(--nav-height) + 1.5rem);
    padding-bottom: 3rem;
  }
  .hero__title {
    max-width: none;
  }
  .hero__summary,
  .hero__support {
    max-width: none;
  }
}

@media (max-width: 640px) {
  .hero__meta {
    gap: 0.35rem 0.75rem;
    font-size: 0.8rem;
  }
  .hero__actions {
    flex-direction: column;
    align-items: stretch;
  }
  .hero__actions .btn {
    justify-content: center;
  }
  .hero__highlights li {
    font-size: 0.88rem;
  }
}
</style>
