---
interface NavItem {
  href: string;
  label: string;
}

interface Props {
  lang: 'en' | 'es';
  items: NavItem[];
}

const { lang, items } = Astro.props;
const ctaLabel = lang === 'en' ? 'Project brief' : 'Brief del proyecto';
const ctaHref = '#contact-form';
const brandTag = lang === 'en' ? 'automation systems' : 'sistemas de automatización';

const switchLabel = lang === 'en' ? 'ES' : 'EN';
const switchHref  = lang === 'en' ? '/es/' : '/en/';
---
<nav class="navbar" aria-label={lang === 'en' ? 'Primary navigation' : 'Navegación principal'}>
  <div class="container">
    <div class="navbar__inner">
      <a class="navbar__brand" href={lang === 'en' ? '/en/' : '/es/'} aria-label="Tooltician">
        <img
          class="navbar__brand-logo"
          src="/assets/images/tooltician-logo-128.webp"
          alt=""
          width="32"
          height="32"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
        <span class="navbar__brand-lockup">
          <span class="navbar__brand-name">Tooltician</span>
          <span class="navbar__brand-tag">{brandTag}</span>
        </span>
      </a>

      <button
        class="navbar__toggle"
        type="button"
        aria-controls="nav-links"
        aria-expanded="false"
        aria-label={lang === 'en' ? 'Toggle menu' : 'Abrir menú'}
      >
        <span></span><span></span><span></span>
      </button>

      <button
        class="navbar__overlay"
        type="button"
        tabindex="-1"
        aria-label={lang === 'en' ? 'Close menu' : 'Cerrar menú'}
        data-nav-close
      ></button>

      <ul class="navbar__links" id="nav-links" role="list">
        {items.map(item => (
          <li>
            <a class="navbar__link" href={item.href}>{item.label}</a>
          </li>
        ))}
        <li>
          <a
            class="navbar__lang-switch"
            href={switchHref}
            hreflang={lang === 'en' ? 'es' : 'en'}
            data-language-preference={lang === 'en' ? 'es' : 'en'}
            aria-label={lang === 'en' ? 'Switch to Spanish' : 'Cambiar a inglés'}
            title={lang === 'en' ? 'Ver en español' : 'View in English'}
          >{switchLabel}</a>
        </li>
        <li>
          <a class="navbar__cta" href={ctaHref}>
            {ctaLabel}
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<style>
.navbar__lang-switch {
  display: inline-flex;
  align-items: center;
  padding: var(--sp-2) var(--sp-3);
  font-family: var(--ff-label);
  font-size: 0.7rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--clr-text-muted);
  border: 1px solid var(--clr-border);
  border-radius: var(--radius-sm);
  transition: color var(--dur-fast), border-color var(--dur-fast), background var(--dur-fast);
}
.navbar__lang-switch:hover {
  color: var(--clr-text);
  border-color: var(--clr-border-strong);
  background: rgba(255, 255, 255, 0.06);
}
.navbar__lang-switch:active {
  background: rgba(255, 255, 255, 0.12);
}

.navbar__brand-lockup {
  display: grid;
  gap: 0.08rem;
}

.navbar__brand-name {
  font-family: var(--ff-heading);
  font-size: 1.02rem;
  line-height: 1;
  letter-spacing: -0.04em;
}

.navbar__brand-tag {
  font-family: var(--ff-label);
  font-size: 0.56rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--clr-accent);
  opacity: 0.7;
}
</style>
