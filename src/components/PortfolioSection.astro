---
<section class="section" id="portfolio">
  <div class="container">
    <div class="section-header section-header--center">
      <span class="section-eyebrow reveal">{c.eyebrow}</span>
      <h2 class="section-title reveal">{c.title}</h2>
      <div class="divider reveal"></div>
      <p class="section-subtitle reveal">{c.subtitle}</p>
    </div>

    <div class="filter-bar reveal" role="group" aria-label={c.fl.label}>
      <span class="filter-label">{c.fl.label}</span>
      <button class="filter-btn active" type="button" data-filter="all" aria-pressed="true">{c.fl.all}</button>
      <button class="filter-btn" type="button" data-filter="python" aria-pressed="false">{c.fl.python}</button>
      <button class="filter-btn" type="button" data-filter="web" aria-pressed="false">{c.fl.web}</button>
      <button class="filter-btn" type="button" data-filter="cli" aria-pressed="false">{c.fl.cli}</button>
      <button class="filter-btn" type="button" data-filter="data" aria-pressed="false">{c.fl.data}</button>
    </div>

    <div class="portfolio-grid" id="portfolio-grid">
      {c.projects.map((proj, i) => (
        <article
          class={`project-card ${proj.featured ? 'project-card--featured' : ''} reveal reveal-delay-${(i % 3) + 1}`}
          id={`project-${proj.id}`}
          data-categories={proj.filters.join(' ')}
        >
          <div class="project-topline">
            <div class="project-tags">
              {proj.tags.map(tag => (
                <span class={`badge badge-${proj.tagType}`}>{tag}</span>
              ))}
            </div>
            <p class="project-impact">{proj.impact}</p>
          </div>

          <div class="project-heading">
            <h3 class="project-title">{proj.title}</h3>
            <p class="project-summary">{proj.summary}</p>
          </div>

          <dl class="project-points">
            <div class="project-point">
              <dt>{c.fl.problem}</dt>
              <dd>{proj.problem}</dd>
            </div>
            <div class="project-point">
              <dt>{c.fl.solution}</dt>
              <dd>{proj.solution}</dd>
            </div>
            <div class="project-point">
              <dt>{c.fl.proof}</dt>
              <dd>{proj.proof}</dd>
            </div>
          </dl>

          <div class="project-links">
            {proj.links.map(l => (
              <a class="project-link" href={l.href} target="_blank" rel="noopener noreferrer">
                <span>{l.label}</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M7 17 17 7" />
                  <path d="M7 7h10v10" />
                </svg>
              </a>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.filter-bar {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: flex-start;
  gap: 0.5rem;
  margin-bottom: 1rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid var(--clr-border);
}

.filter-label {
  font-family: var(--ff-label);
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--clr-text-faint);
  margin-right: 0.5rem;
}

.filter-btn {
  padding: 0.45rem 0.85rem;
  border-radius: var(--radius-sm);
  font-family: var(--ff-label);
  font-size: 0.74rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  border: 1px solid var(--clr-border);
  background: var(--clr-surface);
  color: var(--clr-text-muted);
  cursor: pointer;
  transition: border-color 150ms, background 150ms, color 150ms;
}

.filter-btn:hover {
  border-color: var(--clr-border-strong);
  color: var(--clr-text);
}

.filter-btn:active {
  transform: scale(0.97);
}

.filter-btn.active {
  background: rgba(196, 160, 74, 0.12);
  border-color: rgba(196, 160, 74, 0.2);
  color: var(--clr-text);
}

.portfolio-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0;
  border-top: 1px solid var(--clr-border);
}

.project-card {
  display: grid;
  gap: 1rem;
  padding: 1.3rem 0 1.45rem;
  padding-left: 0;
  border-bottom: 1px solid var(--clr-border);
  transition: padding-left var(--dur-med);
}
.project-card[hidden] {
  display: none !important;
}

.project-card--featured {
  padding-left: 1rem;
  border-left: 2px solid var(--clr-accent);
}

.project-topline {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  align-items: flex-start;
  gap: 0.75rem 1rem;
}

.project-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
}

.project-impact {
  font-family: var(--ff-label);
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--clr-text-faint);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.project-heading {
  display: flex;
  flex-direction: column;
  gap: 0.55rem;
}

.project-title {
  font-family: var(--ff-heading);
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--clr-text);
  letter-spacing: -0.03em;
}

.project-summary {
  font-size: 0.96rem;
  color: var(--clr-text);
  line-height: 1.7;
  max-width: 70ch;
}

.project-points {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1rem;
}

.project-point {
  display: grid;
  gap: 0.25rem;
  padding-top: 0.75rem;
  border-top: 1px solid var(--clr-border);
}

.project-point dt {
  font-family: var(--ff-label);
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--clr-text-faint);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.project-point dd {
  font-size: 0.88rem;
  color: var(--clr-text-muted);
  line-height: 1.6;
}

.project-links {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem 1rem;
}

.project-link {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--clr-accent);
  transition: color 150ms;
}

.project-link:hover {
  color: var(--clr-accent-hover);
}

.project-link:active {
  opacity: 0.7;
}

.project-link svg {
  flex-shrink: 0;
}

@media (max-width: 900px) {
  .project-points {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 640px) {
  .project-points {
    grid-template-columns: 1fr;
  }

  .project-links {
    gap: 0.75rem 1rem;
  }
}
</style>

<script>
const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
const cards = document.querySelectorAll<HTMLElement>('.project-card');

function setFilter(filter: string) {
  btns.forEach((btn) => {
    const active = btn.dataset.filter === filter;
    btn.classList.toggle('active', active);
    btn.setAttribute('aria-pressed', String(active));
  });

  cards.forEach((card) => {
    const categories = (card.dataset.categories ?? '').split(' ').filter(Boolean);
    const match = filter === 'all' || categories.includes(filter);
    card.hidden = !match;
    card.setAttribute('aria-hidden', String(!match));
    if (match) card.classList.add('visible');
  });

  const focused = document.activeElement as HTMLElement | null;
  if (focused && 'hidden' in focused && (focused as HTMLElement).hidden) {
    const firstLink = document.querySelector<HTMLAnchorElement>(
      '.project-card:not([hidden]) .project-link'
    );
    if (firstLink) firstLink.focus();
  }
}

btns.forEach((btn) => {
  btn.addEventListener('click', () => {
    setFilter(btn.dataset.filter ?? 'all');
  });
});
</script>
