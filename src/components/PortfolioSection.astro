  type: 'star' | 'fork' | 'pypi' | 'store' | 'live' | 'ci' | 'metric';
}

interface Project {
  id: string;
  title: string;
  impact: string;
  summary: string;
  problem: string;
  solution: string;
  proof: string;
  tags: string[];
  filters: string[];
  tagType: 'accent' | 'teal' | 'warm' | 'neutral';
  links: { label: string; href: string }[];
  evidence?: EvidenceChip[];
  featured?: boolean;
}

function evidenceBadgeClass(type: EvidenceChip['type']): string {
  if (type === 'star' || type === 'pypi') return 'badge-accent';
  if (type === 'live' || type === 'store') return 'badge-teal';
  return 'badge-neutral';
}

