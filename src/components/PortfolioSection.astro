  projects: lang === 'en' ? projectsEN : projectsES,
  title: lang === 'en' ? 'Production Work Index' : 'Indice de Trabajo en Produccion',
  eyebrow: lang === 'en' ? 'Portfolio' : 'Portafolio',
  subtitle: lang === 'en'
