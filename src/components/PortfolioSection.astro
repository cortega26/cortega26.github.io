---
interface Project {
  id: string;
  title: string;
  impact: string;
  desc: string;
  tags: string[];
  tagType: 'accent' | 'teal' | 'warm' | 'neutral';
  links: { label: string; href: string }[];
  isNew?: boolean;
}

interface Props { lang: 'en' | 'es'; }
const { lang } = Astro.props;

const projectsEN: Project[] = [
  {
    id: 'ebano',
    title: 'El Rincón de Ébano',
    impact: 'Live at elrincondeebano.com · Private residential marketplace',
    desc: 'E-commerce storefront for a private residential community — designed, built, and actively operated as a live business. 100+ SKUs, real-time cart, bundle promotions, product filtering, and WhatsApp-integrated checkout. This is not a demo: it runs daily transactions and I maintain it.',
    tags: ['Astro', 'E-commerce', 'Vite'],
    tagType: 'teal',
    links: [{ label: 'Live site', href: 'https://elrincondeebano.com' }, { label: 'Repo', href: 'https://github.com/cortega26/elrincondeebano' }],
  },
  {
    id: 'monedario',
    title: 'Monedario',
    impact: 'Live at monedario.cl · Chilean personal finance platform',
    desc: 'Personal finance platform for Chilean users — built, launched, and maintained as a live product without advertising or paywalls. Nine guide categories, interactive calculators, and real-time economic indicators (UF, UTM, exchange rates). Updated 2026. This exists because the information should be free and in plain language.',
    tags: ['Astro', 'TypeScript', 'Finance'],
    tagType: 'teal',
    links: [{ label: 'Live site', href: 'https://monedario.cl' }, { label: 'Repo', href: 'https://github.com/cortega26/tuplatainforma' }],
  },
  {
    id: 'rutificador',
    title: 'Rutificador',
    impact: '⭐ 12 stars · 3 forks · Published on PyPI',
    desc: 'Reusable Python library for validating and normalizing Chilean national ID (RUT) numbers — used in data ingestion pipelines, form validation, and batch processing. Published on PyPI with CI, CodeQL scanning, and a CLI for scripted workflows.',
    tags: ['Python', 'PyPI', 'CLI'],
    tagType: 'accent',
    links: [{ label: 'GitHub', href: 'https://github.com/cortega26/rutificador' }, { label: 'PyPI', href: 'https://pypi.org/project/rutificador/' }],
  },
  {
    id: 'conciliador',
    title: 'Conciliador Bancario',
    impact: 'Published on PyPI · Fail-closed audit automation',
    desc: 'Bank reconciliation tool built for audit-grade environments — not just accounting convenience. Fail-closed by design: if the data does not reconcile, the tool halts and reports why, rather than silently producing a wrong result. Append-only audit logs, deterministic outputs, and a traceable record of every run. Distributed via PyPI for reproducible installation.',
    tags: ['Python', 'CLI', 'Audit'],
    tagType: 'accent',
    links: [{ label: 'GitHub', href: 'https://github.com/cortega26/conciliador_bancario' }, { label: 'PyPI', href: 'https://pypi.org/project/bankrecon/' }],
  },
  {
    id: 'noticiencias',
    title: 'Noticiencias',
    impact: 'Live at noticiencias.com · Spanish-language science media, 8 disciplines',
    desc: 'Spanish-language science media site covering astronomy, health, physics, biology, chemistry, and more. Built for readability and SEO over content overload. Category-level editorial governance, source tracking, methodology documentation, and an RSS feed.',
    tags: ['Astro', 'SEO', 'Accessibility'],
    tagType: 'teal',
    links: [{ label: 'Live site', href: 'https://www.noticiencias.com' }, { label: 'Repo', href: 'https://github.com/cortega26/noticiencias' }],
  },
  {
    id: 'dnspect',
    title: 'DNSpect',
    impact: 'DNS benchmarking with statistical rigor',
    desc: 'Statistically defensible DNS benchmarking framework — because p50 lies. Measures resolver performance using proper statistical methods (percentiles, outlier detection) rather than single-sample averages. TypeScript CLI, FastAPI backend, and React dashboard.',
    tags: ['TypeScript', 'FastAPI', 'React'],
    tagType: 'warm',
    links: [{ label: 'Repo', href: 'https://github.com/cortega26/DNSpect' }],
  },
  {
    id: 'polla',
    title: 'Jackpot Data Pipeline',
    impact: '⭐ 5 stars · 1 fork · Recurring production pipeline',
    desc: 'Automated data ingestion pipeline for Chilean lottery results. Scrapes structured jackpot data from a volatile source, normalizes it, and publishes to Google Sheets on a recurring schedule. Designed to survive source changes without manual intervention.',
    tags: ['Python', 'Scraping', 'Google Sheets'],
    tagType: 'accent',
    links: [{ label: 'Repo', href: 'https://github.com/cortega26/polla' }, { label: 'Docs', href: 'https://github.com/cortega26/polla#readme' }],
  },
];

const projectsES: Project[] = [
  {
    id: 'ebano',
    title: 'El Rincón de Ébano',
    impact: 'Activo en elrincondeebano.com · Minimarket residencial privado',
    desc: 'Tienda e-commerce para una comunidad residencial privada — diseñada, desarrollada y operada activamente como un negocio real. Más de 100 SKUs, carrito en tiempo real, promociones por combo, filtrado de productos y checkout integrado con WhatsApp. Esto no es una demo: procesa transacciones diarias y lo mantengo.',
    tags: ['Astro', 'E-commerce', 'Vite'],
    tagType: 'teal',
    links: [{ label: 'Sitio', href: 'https://elrincondeebano.com' }, { label: 'Repo', href: 'https://github.com/cortega26/elrincondeebano' }],
  },
  {
    id: 'monedario',
    title: 'Monedario',
    impact: 'Activo en monedario.cl · Plataforma de finanzas personales para Chile',
    desc: 'Plataforma de finanzas personales para usuarios chilenos — construida, lanzada y mantenida como producto activo sin publicidad ni paywalls. Nueve categorías de guías, calculadoras interactivas e indicadores económicos en tiempo real (UF, UTM, tipo de cambio). Actualizado 2026. Existe porque esta información debería ser gratuita y en lenguaje claro.',
    tags: ['Astro', 'TypeScript', 'Finanzas'],
    tagType: 'teal',
    links: [{ label: 'Sitio', href: 'https://monedario.cl' }, { label: 'Repo', href: 'https://github.com/cortega26/tuplatainforma' }],
  },
  {
    id: 'rutificador',
    title: 'Rutificador',
    impact: '⭐ 12 estrellas · 3 forks · Publicado en PyPI',
    desc: 'Librería Python reutilizable para validar y normalizar RUTs chilenos — usada en pipelines de ingestión de datos, validación de formularios y procesamiento en lote. Publicada en PyPI con CI, escaneo CodeQL y CLI para flujos automatizados.',
    tags: ['Python', 'PyPI', 'CLI'],
    tagType: 'accent',
    links: [{ label: 'GitHub', href: 'https://github.com/cortega26/rutificador' }, { label: 'PyPI', href: 'https://pypi.org/project/rutificador/' }],
  },
  {
    id: 'conciliador',
    title: 'Conciliador Bancario',
    impact: 'Publicado en PyPI · Automatización de auditoría fail-closed',
    desc: 'Herramienta de conciliación bancaria construida para entornos de auditoría — no solo comodidad contable. Diseñada fail-closed: si los datos no coinciden, el sistema se detiene e informa el motivo, en lugar de producir silenciosamente un resultado incorrecto. Logs de auditoría append-only, salidas deterministas y registro trazable de cada ejecución. Distribuido vía PyPI.',
    tags: ['Python', 'CLI', 'Auditoría'],
    tagType: 'accent',
    links: [{ label: 'GitHub', href: 'https://github.com/cortega26/conciliador_bancario' }, { label: 'PyPI', href: 'https://pypi.org/project/bankrecon/' }],
  },
  {
    id: 'noticiencias',
    title: 'Noticiencias',
