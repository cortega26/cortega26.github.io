    desc: 'Sitio de divulgación científica en español que cubre astronomía, salud, física, biología, química y más. Construido para legibilidad y SEO por encima del volumen de contenido. Gobernanza editorial por categoría, rastreo de fuentes, documentación metodológica y feed RSS.',
    tags: ['Astro', 'SEO', 'Accesibilidad'],
    tagType: 'teal',
    links: [{ label: 'Sitio', href: 'https://www.noticiencias.com' }, { label: 'Repo', href: 'https://github.com/cortega26/noticiencias' }],
  },
  {
    id: 'dnspect',
    title: 'DNSpect',
    impact: 'Benchmarking DNS con rigor estadístico',
    desc: 'Framework de benchmarking DNS estadísticamente defendible — porque el p50 miente. Mide el rendimiento de resolvers usando métodos estadísticos correctos (percentiles, detección de outliers) en lugar de promedios de una sola muestra. CLI TypeScript, backend FastAPI y dashboard React.',
    tags: ['TypeScript', 'FastAPI', 'React'],
    tagType: 'warm',
    links: [{ label: 'Repo', href: 'https://github.com/cortega26/DNSpect' }],
  },
  {
    id: 'polla',
    title: 'Pipeline de Datos de Lotería',
    impact: '⭐ 5 estrellas · 1 fork · Pipeline de producción recurrente',
    desc: 'Pipeline automatizado de ingestión de datos para resultados de lotería chilena. Extrae datos estructurados de una fuente volátil, los normaliza y publica en Google Sheets de forma recurrente. Diseñado para sobrevivir cambios en la fuente sin intervención manual.',
    tags: ['Python', 'Scraping', 'Google Sheets'],
    tagType: 'accent',
    links: [{ label: 'Repo', href: 'https://github.com/cortega26/polla' }, { label: 'Docs', href: 'https://github.com/cortega26/polla#readme' }],
  },
];

const filterLabels = {
  en: { all: 'All', python: 'Python', web: 'Web / Astro', cli: 'CLI / Tools', data: 'Data', label: 'Filter:' },
  es: { all: 'Todos', python: 'Python', web: 'Web / Astro', cli: 'CLI / Herramientas', data: 'Datos', label: 'Filtrar:' },
};

const c = {
  projects: lang === 'en' ? projectsEN : projectsES,
  title: lang === 'en' ? 'Work in Production' : 'Trabajo en Producción',
  eyebrow: lang === 'en' ? 'Portfolio' : 'Portafolio',
  subtitle: lang === 'en'
    ? 'Live sites with real users, published packages with CI and CodeQL, and automation that runs in production — not just repositories that demonstrate effort.'
    : 'Sitios activos con usuarios reales, paquetes publicados con CI y CodeQL, y automatización que corre en producción — no solo repositorios que demuestran esfuerzo.',
  fl: filterLabels[lang],
};

const tagCategories: Record<string, string> = {
  'Python': 'python', 'PyPI': 'python', 'CLI': 'cli', 'Audit': 'cli', 'Auditoría': 'cli',
  'Astro': 'web', 'SEO': 'web', 'Accessibility': 'web', 'Accesibilidad': 'web',
  'TypeScript': 'web', 'Finance': 'web', 'Finanzas': 'web', 'E-commerce': 'web', 'Vite': 'web',
  'Scraping': 'data', 'PDF': 'data', 'Extraction': 'data', 'Extracción': 'data', 'Google Sheets': 'data',
  'WebSocket': 'python', 'Alerts': 'python', 'Alertas': 'python', 'FastAPI': 'python', 'React': 'web',
};

function getCategory(tags: string[]): string {
  for (const tag of tags) {
    const cat = tagCategories[tag];
    if (cat) return cat;
  }
  return 'python';
}
---
<section class="section" id="portfolio">
  <div class="container">
    <div class="section-header section-header--center">
      <span class="section-eyebrow reveal">{c.eyebrow}</span>
      <h2 class="section-title reveal">{c.title}</h2>
      <div class="divider reveal"></div>
      <p class="section-subtitle reveal">{c.subtitle}</p>
    </div>

    <div class="filter-bar reveal" role="group" aria-label={c.fl.label}>
      <span class="filter-label">{c.fl.label}</span>
      <button class="filter-btn active" data-filter="all">{c.fl.all}</button>
      <button class="filter-btn" data-filter="python">{c.fl.python}</button>
      <button class="filter-btn" data-filter="web">{c.fl.web}</button>
      <button class="filter-btn" data-filter="cli">{c.fl.cli}</button>
      <button class="filter-btn" data-filter="data">{c.fl.data}</button>
    </div>

    <div class="portfolio-grid" id="portfolio-grid">
      {c.projects.map((proj, i) => (
        <article
          class={`card-glass project-card reveal reveal-delay-${(i % 3) + 1}`}
          id={`project-${proj.id}`}
          data-category={getCategory(proj.tags)}
        >
          {proj.isNew && <span class="new-badge">{lang === 'en' ? 'New' : 'Nuevo'}</span>}
          <div class="project-tags">
            {proj.tags.map(tag => (
              <span class={`badge badge-${proj.tagType}`}>{tag}</span>
            ))}
          </div>
          <h3 class="project-title">{proj.title}</h3>
          <p class="project-impact">{proj.impact}</p>
          <p class="project-desc">{proj.desc}</p>
          <div class="project-links">
            {proj.links.map(l => (
              <a class="btn btn-ghost btn-sm" href={l.href} target="_blank" rel="noopener noreferrer">{l.label} →</a>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.filter-bar {
  display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem;
  margin-bottom: 2.5rem; justify-content: center;
}
.filter-label {
  font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em;
  color: var(--clr-text-faint); margin-right: 0.25rem;
}
.filter-btn {
  padding: 6px 16px; border-radius: var(--radius-full); font-size: 0.8rem; font-weight: 600;
  border: 1px solid var(--clr-border); background: transparent; color: var(--clr-text-muted);
  cursor: pointer; transition: all 150ms;
}
.filter-btn:hover { border-color: var(--clr-border-glow); color: var(--clr-text); }
.filter-btn.active {
  background: var(--clr-accent); border-color: var(--clr-accent); color: #fff;
}

.portfolio-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem;
}
.project-card {
  position: relative; display: flex; flex-direction: column; gap: 0.75rem;
  transition: background 300ms, border-color 300ms, transform 300ms, box-shadow 300ms, opacity 300ms;
}
.project-card.hidden { opacity: 0; pointer-events: none; transform: scale(0.95); }
.new-badge {
  position: absolute; top: 1rem; right: 1rem;
  background: var(--clr-accent-warm); color: #fff;
  font-size: 0.65rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
  padding: 3px 8px; border-radius: var(--radius-full);
}
.project-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }
.project-title {
  font-family: var(--ff-heading); font-size: 1.05rem; font-weight: 700; color: var(--clr-text);
}
.project-impact {
  font-size: 0.75rem; font-weight: 600; color: var(--clr-accent-2);
  text-transform: uppercase; letter-spacing: 0.06em;
}
.project-desc { font-size: 0.87rem; color: var(--clr-text-muted); line-height: 1.55; flex: 1; }
.project-links { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: auto; }

@media (max-width: 1024px) { .portfolio-grid { grid-template-columns: 1fr 1fr; } }
@media (max-width: 640px)  { .portfolio-grid { grid-template-columns: 1fr; } }
</style>

<script>
const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
const cards = document.querySelectorAll<HTMLElement>('.project-card');

btns.forEach(btn => {
  btn.addEventListener('click', () => {
    btns.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const f = btn.dataset.filter!;
    cards.forEach(card => {
      const match = f === 'all' || card.dataset.category === f;
      card.classList.toggle('hidden', !match);
    });
  });
});
</script>
