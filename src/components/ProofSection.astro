---
interface Props { lang: 'en' | 'es'; }
const { lang } = Astro.props;

const en = {
  eyebrow: 'Proof', title: 'Public Proof and Delivery Signals',
  subtitle: 'Public signals for packaging discipline, quality systems, communication style, and work that already exists outside a demo environment.',
  steps: [
    { label: 'Packaging', title: 'Reusable libraries & CLIs', body: 'Projects like rutificador, bankrecon, and Monedario show the same packaging instinct across code and content: reliable structure, clear docs, and outputs people can actually use.' },
    { label: 'Quality', title: 'CI, scans & auditability', body: 'I bias toward test coverage, code scanning, deterministic outputs, and logs that make incidents easier to understand rather than harder to trace.' },
    { label: 'Communication', title: 'English-first, bilingual delivery', body: 'I write public project docs in a way that works for international readers while still supporting Spanish-speaking collaborators and clients.' },
    { label: 'Delivery', title: 'Lightweight systems that hold up', body: 'Automation that saves operator time, front ends that improve comprehension, and repositories that show how the work is maintained.' },
  ],
  proof: [
    { name: 'Rutificador', body: 'Published package, CI workflows, CodeQL, and batch-friendly CLI documentation.', links: [{ label: 'GitHub', href: 'https://github.com/cortega26/rutificador' }, { label: 'PyPI', href: 'https://pypi.org/project/rutificador/' }] },
    { name: 'Conciliador Bancario', body: 'Fail-closed behavior, append-only audit logs, architecture diagrams, and installable distribution.', links: [{ label: 'GitHub', href: 'https://github.com/cortega26/conciliador_bancario' }, { label: 'PyPI', href: 'https://pypi.org/project/bankrecon/' }] },
    { name: 'Noticiencias', body: 'Public front end with documented repo boundary and content validation workflow.', links: [{ label: 'Visit live site', href: 'https://www.noticiencias.com' }, { label: 'View repository', href: 'https://github.com/cortega26/noticiencias' }] },
    { name: 'Monedario', body: 'Live site with finance calculators, editorial governance docs, and deterministic economic-data fallback.', links: [{ label: 'Visit live site', href: 'https://monedario.cl' }, { label: 'View repository', href: 'https://github.com/cortega26/tuplatainforma' }] },
  ],
  resumeLabel: 'Download Resume (PDF)',
  resumeHref: '/assets/docs/carlos-ortega-resume.pdf',
};

const es = {
  eyebrow: 'Evidencia', title: 'Evidencia Pública y Señales de Entrega',
  subtitle: 'Señales públicas sobre disciplina de empaquetado, sistemas de calidad, estilo de comunicación y trabajo que ya existe fuera de una demo.',
  steps: [
    { label: 'Empaquetado', title: 'Librerías y CLIs reutilizables', body: 'Proyectos como rutificador, bankrecon y Monedario muestran el mismo instinto de empaquetado en código y contenido: estructura confiable, docs claros y salidas que la gente puede usar.' },
    { label: 'Calidad', title: 'CI, escaneo y auditabilidad', body: 'Priorizo cobertura de pruebas, escaneo de código, salidas deterministas y logs que facilitan entender incidentes en lugar de complicarlos.' },
    { label: 'Comunicación', title: 'English-first, entrega bilingüe', body: 'Escribo docs públicos de proyectos de forma que funcionen para lectores internacionales sin dejar de apoyar colaboradores y clientes hispanohablantes.' },
    { label: 'Entrega', title: 'Sistemas livianos que aguantan', body: 'Automatización que ahorra tiempo al operador, frontends que mejoran la comprensión y repositorios que muestran cómo se mantiene el trabajo.' },
  ],
  proof: [
    { name: 'Rutificador', body: 'Paquete publicado, flujos CI, CodeQL y documentación CLI batch-friendly.', links: [{ label: 'GitHub', href: 'https://github.com/cortega26/rutificador' }, { label: 'PyPI', href: 'https://pypi.org/project/rutificador/' }] },
    { name: 'Conciliador Bancario', body: 'Comportamiento fail-closed, logs de auditoría append-only, diagramas de arquitectura y distribución instalable.', links: [{ label: 'GitHub', href: 'https://github.com/cortega26/conciliador_bancario' }, { label: 'PyPI', href: 'https://pypi.org/project/bankrecon/' }] },
    { name: 'Noticiencias', body: 'Frontend público con límites de repositorio documentados y flujo de validación de contenido.', links: [{ label: 'Ver sitio', href: 'https://www.noticiencias.com' }, { label: 'Ver repositorio', href: 'https://github.com/cortega26/noticiencias' }] },
    { name: 'Monedario', body: 'Sitio activo con calculadoras financieras, docs de gobernanza editorial y manejo de parámetros económicos.', links: [{ label: 'Ver sitio', href: 'https://monedario.cl' }, { label: 'Ver repositorio', href: 'https://github.com/cortega26/tuplatainforma' }] },
  ],
  resumeLabel: 'Descargar CV (PDF)',
  resumeHref: '/assets/docs/carlos-ortega-resume.pdf',
};

const c = lang === 'en' ? en : es;
---
<section class="section section--alt" id="proof">
  <div class="container">
    <div class="section-header section-header--center">
      <span class="section-eyebrow reveal">{c.eyebrow}</span>
      <h2 class="section-title reveal">{c.title}</h2>
      <div class="divider reveal"></div>
      <p class="section-subtitle reveal">{c.subtitle}</p>
    </div>

    <div class="proof-layout">
      <div class="proof-track">
        {c.steps.map((step, i) => (
          <article class={`proof-step reveal reveal-delay-${(i % 3) + 1}`}>
            <div class="proof-step__meta">
              <span class="proof-step__index">{String(i + 1).padStart(2, '0')}</span>
              <span class="proof-step__label">{step.label}</span>
            </div>
            <div class="proof-step__body">
              <h3 class="proof-step__title">{step.title}</h3>
              <p class="proof-step__text">{step.body}</p>
            </div>
          </article>
        ))}
      </div>

      <div class="proof-catalog">
        {c.proof.map((p, i) => (
          <article class={`proof-entry reveal reveal-delay-${(i % 2) + 1}`}>
            <div class="proof-entry__heading">
              <h4 class="proof-name">{p.name}</h4>
              <p class="proof-body">{p.body}</p>
            </div>
            <div class="proof-links">
              {p.links.map(l => (
                <a class="proof-link" href={l.href} target="_blank" rel="noopener noreferrer">
                  <span>{l.label}</span>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M7 17 17 7" />
                    <path d="M7 7h10v10" />
                  </svg>
                </a>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="proof-resume reveal">
      <a class="btn btn-ghost" href={c.resumeHref} target="_blank" rel="noopener noreferrer">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        {c.resumeLabel}
      </a>
    </div>
  </div>
</section>

<style>
.proof-layout {
  display: grid;
  grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.95fr);
  gap: 2rem;
  margin-bottom: 2rem;
}

.proof-track,
.proof-catalog {
  border-top: 1px solid var(--clr-border);
}

.proof-step,
.proof-entry {
  display: grid;
  gap: 0.75rem;
  padding: 1rem 0 1.1rem;
  border-bottom: 1px solid var(--clr-border);
}

.proof-step__meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-family: var(--ff-label);
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--clr-text-faint);
}

.proof-step__index {
  color: var(--clr-accent);
  min-width: 2.3rem;
}

.proof-step__label {
  color: var(--clr-text);
}

.proof-step__title {
  font-family: var(--ff-heading);
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--clr-text);
  margin-bottom: 0.3rem;
}

.proof-step__text {
  font-size: 0.9rem;
  line-height: 1.65;
  color: var(--clr-text-muted);
}

.proof-entry__heading {
  display: grid;
  gap: 0.35rem;
}

.proof-name {
  font-family: var(--ff-heading);
  font-size: 1rem;
  font-weight: 700;
  color: var(--clr-text);
}
.proof-body {
  font-size: 0.88rem;
  color: var(--clr-text-muted);
  line-height: 1.6;
}

.proof-links {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem 1rem;
}

.proof-link {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--clr-accent);
  transition: color 150ms;
}

.proof-link:hover {
  color: var(--clr-accent-hover);
}

.proof-link:active {
  opacity: 0.7;
}

.proof-resume {
  text-align: left;
  margin-top: 1rem;
}

@media (max-width: 900px) {
  .proof-layout {
    grid-template-columns: 1fr;
  }
}
</style>
