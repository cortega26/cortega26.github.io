---
interface Props {
  lang: 'en' | 'es';
}
const { lang } = Astro.props;

const en = {
  serviceHref: '/en/services/web-technical-hygiene/',
  briefHref: '/en/services/web-technical-hygiene/#contact',
  eyebrow: 'Service with dedicated page',
  title: 'Is your site live but technically abandoned?',
  body: 'Web Technical Hygiene: review, basic hardening, and lightweight monitoring for live sites with no internal technical owner. Security headers, HTTPS, DNS, forms, Search Console, and small verifiable fixes — with a before/after report.',
  fits: [
    'SMBs with a live site and no internal technical team.',
    'Agencies needing external support for recurring low-margin maintenance.',
    'Professionals and consultants where the site generates leads or reputation.',
  ],
  disclaimer: 'No alarmism. No promises of total security. Just clear technical review, verifiable fixes, and a before/after report.',
  priceEyebrow: 'Diagnostic',
  price: '$69',
  priceSub: 'one-time',
  priceNote: 'Applied as a credit toward any implementation plan.',
  monthlyEyebrow: 'Monthly support',
  monthlyPrice: 'from $279/mo',
  monthlySub: '',
  monthlyNote: 'Lightweight monitoring, periodic reviews, and small fixes — no internal hire needed.',
  ctaFull: 'View the full service',
  ctaBrief: 'Request a diagnostic',
  ctaPlans: 'View all plans →',
};

const es = {
  serviceHref: '/es/servicios/higiene-tecnica-web/',
  briefHref: '/es/servicios/higiene-tecnica-web/#brief',
  eyebrow: 'Servicio con página propia',
  title: '¿Tu sitio está online, pero técnicamente abandonado?',
  body: 'Higiene Técnica Web: revisión, hardening básico y monitoreo liviano para sitios publicados que no tienen equipo técnico interno. Headers de seguridad, HTTPS, DNS, formularios, Search Console y pequeñas correcciones verificables — con reporte antes/después.',
  fits: [
    'Empresas con sitio publicado y sin responsable técnico interno.',
    'Agencias que necesitan apoyo externo para mantención recurrente de bajo margen.',
    'Profesionales y consultoras donde el sitio genera leads o reputación.',
  ],
  disclaimer: 'Sin alarmismo. Sin promesas de seguridad total. Solo revisión técnica clara, correcciones verificables y evidencia antes/después.',
  priceEyebrow: 'Entrada',
  price: '1 UF',
  priceSub: 'aprox. CLP $41.000',
  priceNote: 'Diagnóstico inicial descontable si contratas implementación.',
  monthlyEyebrow: 'Soporte mensual',
  monthlyPrice: 'desde 4 UF/mes',
  monthlySub: 'aprox. CLP $162.000/mes',
  monthlyNote: 'Monitoreo liviano, revisiones periódicas y pequeñas correcciones sin incorporar un perfil interno.',
  ctaFull: 'Ver el servicio completo',
  ctaBrief: 'Solicitar diagnóstico',
  ctaPlans: 'Ver todos los planes →',
};

const c = lang === 'en' ? en : es;
---
<section class="section svc-spotlight" id="svc-spotlight">
  <div class="container">
    <div class="svc-spotlight__inner card-glass reveal">
      <div class="svc-spotlight__grid">
        <div class="svc-spotlight__main">
          <span class="section-eyebrow">{c.eyebrow}</span>
          <h2 class="svc-spotlight__title">{c.title}</h2>
          <p class="svc-spotlight__body">
            {c.body}
          </p>
          <ul class="svc-spotlight__fits">
            {c.fits.map(fit => <li>{fit}</li>)}
          </ul>
          <div class="svc-spotlight__actions">
            <a class="btn btn-primary" href={c.serviceHref}>{c.ctaFull}</a>
            <a class="btn btn-ghost" href={c.briefHref}>{c.ctaBrief}</a>
          </div>
          <p class="svc-spotlight__disclaimer">{c.disclaimer}</p>
        </div>

        <aside class="svc-spotlight__aside" aria-label={lang === 'en' ? 'Reference pricing' : 'Precios de referencia'}>
          <div class="svc-spotlight__price-block">
            <p class="svc-spotlight__price-eyebrow">{c.priceEyebrow}</p>
            <p class="svc-spotlight__price">{c.price}</p>
            <p class="svc-spotlight__price-sub">{c.priceSub}</p>
            <p class="svc-spotlight__price-note">{c.priceNote}</p>
          </div>
          <div class="svc-spotlight__divider" aria-hidden="true"></div>
          <div class="svc-spotlight__price-block">
            <p class="svc-spotlight__price-eyebrow">{c.monthlyEyebrow}</p>
            <p class="svc-spotlight__price">{c.monthlyPrice}</p>
            {c.monthlySub && <p class="svc-spotlight__price-sub">{c.monthlySub}</p>}
            <p class="svc-spotlight__price-note">{c.monthlyNote}</p>
          </div>
          <a class="svc-spotlight__aside-cta" href={c.serviceHref}>
            {c.ctaPlans}
          </a>
        </aside>
      </div>
    </div>
  </div>
</section>

<style>
.svc-spotlight__inner {
  padding: var(--sp-8, 2rem);
}

.svc-spotlight__grid {
  display: grid;
  grid-template-columns: minmax(0, 1.5fr) minmax(220px, 0.5fr);
  gap: 2.5rem;
  align-items: start;
}

.svc-spotlight__title {
  font-family: var(--ff-heading);
  font-size: clamp(1.4rem, 2.5vw, 2rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.15;
  margin: 0.6rem 0 1rem;
  text-wrap: balance;
}

.svc-spotlight__body {
  color: var(--clr-text-muted);
  line-height: 1.75;
  max-width: 60ch;
  margin-bottom: 1.25rem;
}

.svc-spotlight__fits {
  display: grid;
  gap: 0.55rem;
  margin-bottom: 1.5rem;
}

.svc-spotlight__fits li {
  position: relative;
  padding-left: 1rem;
  font-size: 0.9rem;
  color: var(--clr-text-muted);
  line-height: 1.6;
}

.svc-spotlight__fits li::before {
  content: '›';
  position: absolute;
  left: 0;
  color: var(--clr-accent);
  font-weight: 700;
}

.svc-spotlight__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-bottom: 1rem;
}

.svc-spotlight__disclaimer {
  color: var(--clr-text-faint);
  font-size: 0.8rem;
  line-height: 1.6;
  max-width: 52ch;
}

.svc-spotlight__aside {
  display: grid;
  gap: 1.25rem;
  border: 1px solid var(--clr-border);
  border-radius: var(--radius-md);
  padding: 1.25rem;
  background: rgba(255, 255, 255, 0.02);
}

.svc-spotlight__price-eyebrow {
  font-family: var(--ff-label);
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--clr-text-faint);
  margin-bottom: 0.3rem;
}

.svc-spotlight__price {
  font-family: var(--ff-heading);
  font-size: 1.5rem;
  font-weight: 700;
  letter-spacing: -0.03em;
  color: var(--clr-accent);
  line-height: 1;
  margin-bottom: 0.25rem;
}

.svc-spotlight__price-sub {
  color: var(--clr-text-faint);
  font-size: 0.8rem;
  line-height: 1.5;
  margin-bottom: 0.4rem;
}

.svc-spotlight__price-note {
  color: var(--clr-text-muted);
  font-size: 0.82rem;
  line-height: 1.6;
}

.svc-spotlight__divider {
  height: 1px;
  background: var(--clr-border);
}

.svc-spotlight__aside-cta {
  font-family: var(--ff-label);
  font-size: 0.72rem;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--clr-accent);
  transition: color var(--dur-fast);
}

.svc-spotlight__aside-cta:hover {
  color: var(--clr-text);
}

@media (max-width: 860px) {
  .svc-spotlight__grid {
    grid-template-columns: 1fr;
  }

  .svc-spotlight__aside {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-items: start;
  }

  .svc-spotlight__divider {
    display: none;
  }

  .svc-spotlight__aside-cta {
    grid-column: 1 / -1;
  }
}

@media (max-width: 540px) {
  .svc-spotlight__aside {
    grid-template-columns: 1fr;
  }

  .svc-spotlight__divider {
    display: block;
  }
}
</style>
