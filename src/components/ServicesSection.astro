---
interface Props { lang: 'en' | 'es'; }
const { lang } = Astro.props;

const SVG_REFRESH  = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 2v6h-6"/><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M3 22v-6h6"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/></svg>';
const SVG_SEARCH   = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>';
const SVG_LAYERS   = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/></svg>';
const SVG_GLOBE    = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>';
const SVG_SHIELD   = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>';
const SVG_CHART    = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>';

const en = {
  eyebrow: 'Services', title: 'Seven Scoped Services',
  subtitle: 'Seven specific services. Each maps to a recurring workflow failure that keeps operations teams stuck in manual work or without ongoing technical oversight.',
  fitLabel: 'Best when:',
  ctaLabel: 'View service',
  services: [
    { icon: SVG_REFRESH, title: 'Reporting Automation', desc: 'Replace recurring report assembly and back-office steps with scheduled or reproducible runs that emit the same answer every time.', fit: 'Inputs, outputs, and workflow ownership are already known.', examples: [{ name: 'Polla App', href: 'https://github.com/cortega26/polla' }, { name: 'Conciliador Bancario', href: 'https://github.com/cortega26/conciliador_bancario' }] },
    { icon: SVG_SEARCH,  title: 'Recurring Data Collection', desc: 'Build scraping and acquisition flows that can be rerun safely, logged properly, and repaired without starting from zero.', fit: 'The team needs dependable collection, not a one-off demo scrape.', examples: [{ name: 'Jackpot Pipeline', href: 'https://github.com/cortega26/polla' }, { name: 'Noticiencias', href: 'https://github.com/cortega26/noticiencias' }] },
    { icon: SVG_LAYERS,  title: 'Operator-Ready Internal Tools', desc: 'Package scripts behind internal APIs or guided interfaces so the workflow stays usable after the original builder steps away.', fit: 'Several people touch the same workflow and handoff risk is real.', examples: [{ name: 'Rutificador', href: 'https://github.com/cortega26/rutificador' }, { name: 'DNSpect', href: 'https://github.com/cortega26/DNSpect' }] },
    { icon: SVG_GLOBE,   title: 'Public Technical Surfaces', desc: 'Build lean Astro and web app surfaces that explain the system clearly, convert the right leads, and stay maintainable.', fit: 'The site needs evidence and clarity more than decorative marketing.', examples: [{ name: 'Monedario', href: 'https://monedario.cl' }, { name: 'El Rincón de Ébano', href: 'https://elrincondeebano.com' }] },
    { icon: SVG_SHIELD,  title: 'Fail-Closed Financial Controls', desc: 'Implement reconciliation and finance workflows that stop on mismatches, preserve audit traces, and make review easier.', fit: 'A wrong answer is more expensive than a slower explicit check.', examples: [{ name: 'Conciliador Bancario', href: 'https://github.com/cortega26/conciliador_bancario' }, { name: 'Portfolio Manager Unified', href: 'https://github.com/cortega26/portfolio-manager-server' }] },
    { icon: SVG_CHART,   title: 'Structured Data Delivery', desc: 'Produce outputs, dashboards, or publishing flows that remove manual copy-paste and make downstream use more predictable.', fit: 'The pain sits in recurring delivery, not a single isolated analysis.', examples: [{ name: 'Polla App', href: 'https://github.com/cortega26/polla' }, { name: 'Portfolio Manager Unified', href: 'https://github.com/cortega26/portfolio-manager-server' }] },
    { icon: SVG_SHIELD,  title: 'Web Technical Hygiene', desc: 'Review security headers, HTTPS, DNS, forms, Search Console, and basic monitoring for live sites that have no internal technical owner.', fit: 'The site is live, commercially matters, and nobody is reviewing the basics regularly.', examples: [{ name: 'DNSpect', href: 'https://github.com/cortega26/DNSpect' }, { name: 'Monedario', href: 'https://monedario.cl' }], href: '/en/services/web-technical-hygiene/' },
  ],
  examplesLabel: 'Evidence:',
};

const es = {
  eyebrow: 'Servicios', title: 'Siete servicios acotados',
  subtitle: 'Siete servicios específicos. Cada uno responde a una falla recurrente de flujo que mantiene a los equipos operativos atrapados en trabajo manual o sin criterio técnico continuo.',
  fitLabel: 'Encaja cuando:',
  ctaLabel: 'Ver servicio',
  services: [
    { icon: SVG_REFRESH, title: 'Automatización de Reportes', desc: 'Reemplazo armado recurrente de reportes y pasos de back-office por ejecuciones programadas o reproducibles que entregan la misma respuesta cada vez.', fit: 'Ya se conocen inputs, outputs y dueño del flujo.', examples: [{ name: 'Polla App', href: 'https://github.com/cortega26/polla' }, { name: 'Conciliador Bancario', href: 'https://github.com/cortega26/conciliador_bancario' }] },
    { icon: SVG_SEARCH,  title: 'Recolección de Datos Recurrente', desc: 'Construyo flujos de scraping y adquisición que pueden reejecutarse con seguridad, quedar bien logueados y repararse sin partir de cero.', fit: 'El equipo necesita recolección confiable, no un scrape de demostración.', examples: [{ name: 'Pipeline de Lotería', href: 'https://github.com/cortega26/polla' }, { name: 'Noticiencias', href: 'https://github.com/cortega26/noticiencias' }] },
    { icon: SVG_LAYERS,  title: 'Herramientas Internas Operables', desc: 'Empaqueto scripts detrás de APIs internas o interfaces guiadas para que el flujo siga siendo usable cuando el autor ya no está encima.', fit: 'Varias personas tocan el mismo flujo y el riesgo de traspaso es real.', examples: [{ name: 'Rutificador', href: 'https://github.com/cortega26/rutificador' }, { name: 'DNSpect', href: 'https://github.com/cortega26/DNSpect' }] },
    { icon: SVG_GLOBE,   title: 'Superficies Técnicas Públicas', desc: 'Construyo sitios Astro y superficies web sobrias que explican el sistema con claridad, convierten al lead correcto y siguen siendo mantenibles.', fit: 'El sitio necesita evidencia y claridad más que marketing decorativo.', examples: [{ name: 'Monedario', href: 'https://monedario.cl' }, { name: 'El Rincón de Ébano', href: 'https://elrincondeebano.com' }] },
    { icon: SVG_SHIELD,  title: 'Controles Financieros Fail-Closed', desc: 'Implemento flujos financieros y de conciliación que se detienen ante diferencias, preservan trazas de auditoría y facilitan la revisión.', fit: 'Una respuesta equivocada cuesta más que una verificación explícita un poco más lenta.', examples: [{ name: 'Conciliador Bancario', href: 'https://github.com/cortega26/conciliador_bancario' }, { name: 'Portfolio Manager Unified', href: 'https://github.com/cortega26/portfolio-manager-server' }] },
    { icon: SVG_CHART,   title: 'Entrega Estructurada de Datos', desc: 'Genero salidas, dashboards o flujos de publicación que eliminan el copia-pega manual y vuelven más predecible el consumo aguas abajo.', fit: 'El dolor está en la entrega recurrente, no en un análisis aislado.', examples: [{ name: 'Polla App', href: 'https://github.com/cortega26/polla' }, { name: 'Portfolio Manager Unified', href: 'https://github.com/cortega26/portfolio-manager-server' }] },
    { icon: SVG_SHIELD,  title: 'Higiene Técnica Web', desc: 'Reviso headers, HTTPS, DNS, formularios, Search Console y monitoreo liviano para sitios publicados que no tienen responsable técnico interno.', fit: 'El sitio ya está online, importa comercialmente y nadie está revisando lo básico con regularidad.', examples: [{ name: 'DNSpect', href: 'https://github.com/cortega26/DNSpect' }, { name: 'Monedario', href: 'https://monedario.cl' }], href: '/es/servicios/higiene-tecnica-web/' },
  ],
  examplesLabel: 'Evidencia:',
};

const c = lang === 'en' ? en : es;
---
<section class="section" id="services">
  <div class="container">
    <div class="section-header section-header--center">
      <span class="section-eyebrow reveal">{c.eyebrow}</span>
      <h2 class="section-title reveal">{c.title}</h2>
      <div class="divider reveal"></div>
      <p class="section-subtitle reveal">{c.subtitle}</p>
    </div>
    <div class="services-grid">
      {c.services.map((svc, i) => (
        <article class={`card-glass svc-card ${svc.href ? 'svc-card--linked' : ''} reveal reveal-delay-${(i % 2) + 1}`}>
          <div class="component-icon" set:html={svc.icon}></div>
          <h3 class="card-title">{svc.title}</h3>
          <p class="svc-desc">{svc.desc}</p>
          <p class="svc-fit"><span>{c.fitLabel}</span> {svc.fit}</p>
          {svc.href && (
            <a class="btn btn-ghost btn-sm svc-inline-cta" href={svc.href}>{c.ctaLabel}</a>
          )}
          <p class="svc-examples-label">{c.examplesLabel}</p>
          <div class="svc-examples">
            {svc.examples.map(ex => (
              <a class="badge badge-accent" href={ex.href} target="_blank" rel="noopener noreferrer">{ex.name}</a>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.services-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: var(--sp-6);
}
.svc-desc { font-size: 0.87rem; color: var(--clr-text-muted); line-height: 1.55; margin-bottom: 1rem; flex: 1; }
.svc-fit {
  font-size: 0.78rem;
  line-height: 1.6;
  color: var(--clr-text-faint);
  margin-bottom: 0.85rem;
}
.svc-fit span {
  color: var(--clr-text);
  font-weight: 600;
}
.svc-examples-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--clr-text-faint); margin-bottom: 0.5rem; }
.svc-examples { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.svc-card { display: flex; flex-direction: column; }
.svc-card--linked {
  border-color: rgba(196, 160, 74, 0.18);
  background: linear-gradient(180deg, rgba(196, 160, 74, 0.05), rgba(255, 255, 255, 0.03));
}
.svc-inline-cta {
  align-self: flex-start;
  margin-bottom: 1rem;
}

@media (max-width: 980px) {
  .services-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 720px) {
  .services-grid {
    grid-template-columns: 1fr;
  }
}
</style>
