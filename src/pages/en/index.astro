---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import HeroSection from '../../components/HeroSection.astro';
import ServicesSection from '../../components/ServicesSection.astro';
import ServiceSpotlight from '../../components/ServiceSpotlight.astro';
import PortfolioSection from '../../components/PortfolioSection.astro';
import AboutSection from '../../components/AboutSection.astro';
import ProofSection from '../../components/ProofSection.astro';
import ContactSection from '../../components/ContactSection.astro';
import ResultsBand from '../../components/ResultsBand.astro';
import '../../styles/global.css';

const navItems = [
  { href: '#overview',     label: 'Overview' },
  { href: '#proof',        label: 'Proof' },
  { href: '#portfolio',    label: 'Work' },
  { href: '#services',     label: 'Services' },
  { href: '#about',        label: 'About' },
  { href: '#contact',      label: 'Brief' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': ['Person', 'ProfessionalService'],
  name: 'Carlos Ortega Gonzalez',
  alternateName: 'Tooltician',
  url: 'https://tooltician.com/',
  sameAs: ['https://github.com/cortega26', 'https://www.linkedin.com/in/cortega26'],
  jobTitle: 'Python Automation & Web Technical Hygiene Consultant',
  description: 'I build Python automation systems and cover web technical hygiene for live sites — ETL pipelines, scrapers, internal tools, reporting workflows, and security/SEO reviews — scoped, documented, and designed to keep running after handoff.',
  areaServed: ['CL', 'Worldwide'],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Santiago',
    addressCountry: 'CL',
  },
  makesOffer: [
    { '@type': 'Offer', name: 'ETL & Workflow Automation', description: 'Scheduled and reproducible ETL pipelines with clear outputs.' },
    { '@type': 'Offer', name: 'Scraping & Data Acquisition', description: 'Resilient collection workflows built for recurring production use.' },
    { '@type': 'Offer', name: 'Internal APIs & Reliability', description: 'Packaged workflows and APIs usable by teams, not just the author.' },
    { '@type': 'Offer', name: 'Static Sites & Front Ends', description: 'Production-ready Astro sites with SEO and performance baked in.' },
    { '@type': 'Offer', name: 'Financial & Audit Tooling', description: 'Fail-closed reconciliation workflows with deterministic audit artifacts.' },
    { '@type': 'Offer', name: 'Reporting & Data Delivery', description: 'Structured outputs and dashboards that eliminate manual copy-paste.' },
    { '@type': 'Offer', name: 'Web Technical Hygiene', description: 'Security headers, HTTPS, DNS, forms, Search Console, and lightweight monitoring for live sites with no internal technical owner. Diagnostic from $69.', url: 'https://tooltician.com/en/services/web-technical-hygiene/' },
  ],
  knowsAbout: [
    'Python Automation', 'ETL Pipelines', 'Data Engineering',
    'Web Scraping', 'Internal APIs', 'Reporting Automation',
    'Static Sites', 'Financial Tooling', 'Web Technical Hygiene',
    'Security Headers', 'DNS Configuration', 'Search Console',
  ],
  hasOccupation: {
    '@type': 'Occupation',
    name: 'Python Automation Consultant',
    description: 'Scoped implementation of ETL pipelines, scrapers, internal APIs, and reporting workflows with CI, documentation, and handoff-ready systems.',
    skills: 'Python, SQL, FastAPI, Selenium, BeautifulSoup, Pandas, Astro, GitHub Actions, CI/CD',
  },
  itemListElement: [
    { '@type': 'ListItem', position: 1, item: { '@type': 'SoftwareApplication', name: 'El Rincón de Ébano', url: 'https://elrincondeebano.com', description: 'Live e-commerce storefront for a private residential community, actively operated.' } },
    { '@type': 'ListItem', position: 2, item: { '@type': 'SoftwareApplication', name: 'Portfolio Manager', url: 'https://github.com/cortega26/portfolio-manager-server', description: 'Desktop-first Electron portfolio tracker with Fastify, SQLite, deterministic finance math, and local-only persistence.' } },
    { '@type': 'ListItem', position: 3, item: { '@type': 'SoftwareApplication', name: 'Monedario', url: 'https://monedario.cl', description: 'Personal finance platform for Chile with real-time economic indicators and interactive calculators.' } },
    { '@type': 'ListItem', position: 4, item: { '@type': 'SoftwareApplication', name: 'LinkedIn Spam Blocker', url: 'https://github.com/cortega26/stop-spam-linkedin', description: 'Privacy-first Chrome and Firefox extension that hides LinkedIn engagement-bait spam locally in the browser.' } },
    { '@type': 'ListItem', position: 5, item: { '@type': 'SoftwareApplication', name: 'Conciliador Bancario', url: 'https://pypi.org/project/bankrecon/', description: 'Fail-closed bank reconciliation tool published on PyPI with audit-grade output.' } },
    { '@type': 'ListItem', position: 6, item: { '@type': 'SoftwareApplication', name: 'Rutificador', url: 'https://pypi.org/project/rutificador/', description: 'Published PyPI library for validating and normalizing Chilean RUT numbers.' } },
    { '@type': 'ListItem', position: 7, item: { '@type': 'WebSite', name: 'Noticiencias', url: 'https://noticiencias.com', description: 'Spanish-language science media site covering 8 disciplines.' } },
  ],
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Tooltician', item: 'https://tooltician.com/' },
    { '@type': 'ListItem', position: 2, name: 'English', item: 'https://tooltician.com/en/' },
  ],
};
---
<BaseLayout
  title="Python Automation & Web Technical Hygiene | Tooltician"
  description="Tooltician: Python automation (ETL, scraping, internal tools, reporting) and web technical hygiene for live sites — security headers, HTTPS, DNS, Search Console. Scoped delivery, public evidence, published pricing."
  lang="en"
  canonical="https://tooltician.com/en/"
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  </Fragment>

  <Navbar lang="en" items={navItems} />

  <main id="main">
    <HeroSection lang="en" />
    <ResultsBand lang="en" />
    <PortfolioSection lang="en" />
    <ServicesSection lang="en" />
    <ServiceSpotlight lang="en" />
    <ProofSection lang="en" />
    <AboutSection lang="en" />
    <ContactSection lang="en" />
  </main>

  <Footer lang="en" />
</BaseLayout>
