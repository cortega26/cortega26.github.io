---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import HeroSection from '../../components/HeroSection.astro';
import ServicesSection from '../../components/ServicesSection.astro';
import PortfolioSection from '../../components/PortfolioSection.astro';
import AboutSection from '../../components/AboutSection.astro';
import ProofSection from '../../components/ProofSection.astro';
import ContactSection from '../../components/ContactSection.astro';
import FaqSection from '../../components/FaqSection.astro';
import ServiceSpotlight from '../../components/ServiceSpotlight.astro';
import ResultsBand from '../../components/ResultsBand.astro';
import '../../styles/global.css';

const navItems = [
  { href: '#overview',     label: 'Resumen' },
  { href: '#proof',        label: 'Evidencia' },
  { href: '#portfolio',    label: 'Trabajo' },
  { href: '#services',     label: 'Servicios' },
  { href: '#about',        label: 'Perfil' },
  { href: '#contact',      label: 'Contacto' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': ['Person', 'ProfessionalService'],
  name: 'Carlos Ortega Gonzalez',
  alternateName: 'Tooltician',
  url: 'https://tooltician.com/es/',
  sameAs: ['https://github.com/cortega26', 'https://www.linkedin.com/in/cortega26'],
  jobTitle: 'Consultor de Automatización Python e Higiene Técnica Web',
  description: 'Construyo sistemas de automatización Python y cubro higiene técnica web para sitios publicados — pipelines ETL, scrapers, APIs internas, flujos de reportes, revisión de headers, HTTPS, DNS y Search Console — con alcance definido y documentación para traspaso.',
  areaServed: ['CL', 'Worldwide'],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Santiago',
    addressCountry: 'CL',
  },
  makesOffer: [
    { '@type': 'Offer', name: 'ETL y Automatización de Flujos', description: 'Pipelines ETL programados y reproducibles con salidas claras.' },
    { '@type': 'Offer', name: 'Scraping y Adquisición de Datos', description: 'Flujos de recolección resilientes para uso recurrente.' },
    { '@type': 'Offer', name: 'APIs Internas y Confiabilidad', description: 'Paquetes y APIs utilizables por equipos, no solo por el autor.' },
    { '@type': 'Offer', name: 'Sitios Estáticos y Frontends', description: 'Sitios Astro listos para producción con SEO y rendimiento integrados.' },
    { '@type': 'Offer', name: 'Higiene Técnica Web y Confianza Digital', description: 'Mantención técnica web, hardening básico, monitoreo liviano y documentación para sitios publicados sin equipo técnico interno.' },
    { '@type': 'Offer', name: 'Herramientas Financieras y de Auditoría', description: 'Flujos fail-closed con artefactos de auditoría deterministas.' },
    { '@type': 'Offer', name: 'Reportes y Entrega de Datos', description: 'Salidas estructuradas y dashboards que eliminan el copia-pega manual.' },
  ],
  knowsAbout: [
    'Automatización Python', 'Pipelines ETL', 'Data Engineering',
    'Web Scraping', 'APIs Internas', 'Automatización de Reportes',
    'Sitios Estáticos', 'Herramientas Financieras',
    'Higiene Técnica Web', 'Headers de Seguridad', 'DNS', 'Search Console',
  ],
  hasOccupation: {
    '@type': 'Occupation',
    name: 'Consultor de Automatización Python',
    description: 'Implementación acotada de pipelines ETL, scrapers, APIs internas y flujos de reportes con CI, documentación y sistemas listos para traspaso.',
    skills: 'Python, SQL, FastAPI, Selenium, BeautifulSoup, Pandas, Astro, GitHub Actions, CI/CD',
  },
  itemListElement: [
    { '@type': 'ListItem', position: 1, item: { '@type': 'SoftwareApplication', name: 'El Rincón de Ébano', url: 'https://elrincondeebano.com', description: 'Tienda e-commerce para comunidad residencial privada, operada activamente.' } },
    { '@type': 'ListItem', position: 2, item: { '@type': 'SoftwareApplication', name: 'Portfolio Manager', url: 'https://github.com/cortega26/portfolio-manager-server', description: 'Gestor de portafolio desktop-first en Electron con Fastify, SQLite, matemática financiera determinista y persistencia local.' } },
    { '@type': 'ListItem', position: 3, item: { '@type': 'SoftwareApplication', name: 'chile-hub', url: 'https://github.com/cortega26/chile-hub', description: 'Registro de datos curados para Chile con builds ETL automatizados, validación de esquemas y descargas multiformato.' } },
    { '@type': 'ListItem', position: 4, item: { '@type': 'SoftwareApplication', name: 'Monedario', url: 'https://monedario.cl', description: 'Plataforma de finanzas personales para Chile con calculadoras y datos en tiempo real.' } },
    { '@type': 'ListItem', position: 5, item: { '@type': 'SoftwareApplication', name: 'LinkedIn Spam Blocker', url: 'https://github.com/cortega26/stop-spam-linkedin', description: 'Extensión para Chrome y Firefox centrada en privacidad que oculta spam de engagement-bait en LinkedIn de forma local en el navegador.' } },
    { '@type': 'ListItem', position: 6, item: { '@type': 'SoftwareApplication', name: 'Conciliador Bancario', url: 'https://pypi.org/project/bankrecon/', description: 'Herramienta de conciliación bancaria fail-closed publicada en PyPI.' } },
    { '@type': 'ListItem', position: 7, item: { '@type': 'SoftwareApplication', name: 'Rutificador', url: 'https://pypi.org/project/rutificador/', description: 'Librería Python publicada en PyPI para validar y normalizar RUTs chilenos.' } },
    { '@type': 'ListItem', position: 8, item: { '@type': 'WebSite', name: 'Noticiencias', url: 'https://noticiencias.com', description: 'Sitio de divulgación científica en español, 8 disciplinas.' } },
  ],
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Tooltician', item: 'https://tooltician.com/' },
    { '@type': 'ListItem', position: 2, name: 'Español', item: 'https://tooltician.com/es/' },
  ],
};
---
<BaseLayout
  title="Consultor de Automatización Python y Servicios de Higiene Técnica Web | Tooltician"
  description="Tooltician: servicios profesionales de automatización Python (ETL, scrapers, reportes) y consultoría de higiene técnica web (headers, HTTPS, DNS) para sitios publicados. Evidencia y presupuestos públicos."
  lang="es"
  canonical="https://tooltician.com/es/"
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  </Fragment>

  <Navbar lang="es" items={navItems} />

  <main id="main">
    <HeroSection lang="es" />
    <ResultsBand lang="es" />
    <PortfolioSection lang="es" />
    <ServicesSection lang="es" />
    <ServiceSpotlight lang="es" />
    <ProofSection lang="es" />
    <AboutSection lang="es" />
    <FaqSection lang="es" />
    <ContactSection lang="es" />
  </main>

  <Footer lang="es" />
</BaseLayout>
