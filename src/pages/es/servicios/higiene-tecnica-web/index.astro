  letter-spacing: -0.04em;
}

.diagnostic-band__copy p:last-child {
  color: var(--clr-text-muted);
  line-height: 1.65;
}

.diagnostic-band__panel {
  display: grid;
  gap: 0.85rem;
  align-content: stretch;
}

.diagnostic-band__cta {
  justify-content: center;
  width: 100%;
}

.diagnostic-strip {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.65rem;
}

.diagnostic-strip--stacked {
  grid-template-columns: 1fr;
}

.diagnostic-strip__item {
  display: grid;
  gap: 0.2rem;
  align-content: start;
  min-width: 0;
  padding: 0.75rem;
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.035);
}

.diagnostic-strip__item span {
  font-family: var(--ff-label);
  font-size: 0.62rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--clr-text-faint);
}

.diagnostic-strip__item strong {
  font-family: var(--ff-heading);
  font-size: clamp(1rem, 1.8vw, 1.25rem);
  line-height: 1.08;
  letter-spacing: -0.03em;
  color: var(--clr-text);
  overflow-wrap: anywhere;
}

.diagnostic-strip__item small {
  color: var(--clr-text-muted);
  font-size: 0.72rem;
  line-height: 1.35;
}

.symptom-grid,
.decision-grid,
.commercial-paths,
.judgment-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: var(--sp-4);
}

.symptom-card,
.decision-card,
.commercial-path,
.judgment-card {
  border: 1px solid var(--clr-border);
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.03);
  padding: var(--sp-5, 1.25rem);
}

.symptom-card,
.decision-card,
.judgment-card {
  display: grid;
  gap: 0.55rem;
}

.symptom-card__num,
.decision-card__prompt,
.judgment-card__label,
.decoy-note__label {
  font-family: var(--ff-label);
  font-size: 0.68rem;
  color: var(--clr-accent);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.symptom-card h3,
.decision-card h3,
.commercial-path h3,
.judgment-card h3,
.decoy-note h3 {
  font-family: var(--ff-heading);
  font-size: 1rem;
  line-height: 1.2;
  letter-spacing: -0.02em;
}

.symptom-card p,
.decision-card p,
.commercial-path p,
.judgment-card p,
.decoy-note p {
  color: var(--clr-text-muted);
  font-size: 0.86rem;
  line-height: 1.6;
}

.decision-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.decision-card {
  position: relative;
  overflow: hidden;
  min-height: 11rem;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.02)),
    radial-gradient(circle at 100% 0%, rgba(196, 160, 74, 0.1), transparent 34%);
}

.decision-card::after {
  content: '';
  position: absolute;
  inset: auto 1rem 1rem auto;
  width: 3rem;
  height: 1px;
  background: var(--clr-accent);
  opacity: 0.28;
}

.decision-card h3 {
  font-size: clamp(1.1rem, 2vw, 1.45rem);
  max-width: 18ch;
}

.judgment-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.judgment-card {
  border-color: rgba(196, 160, 74, 0.16);
  background: rgba(196, 160, 74, 0.035);
}

.inline-cta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  border: 1px solid rgba(196, 160, 74, 0.2);
  border-radius: var(--radius-md);
  background: rgba(196, 160, 74, 0.055);
  padding: var(--sp-5, 1.25rem) var(--sp-6);
}

.inline-cta p {
  color: var(--clr-text);
  font-weight: 600;
  line-height: 1.5;
  max-width: 62ch;
}

.service-summary__list,
.checklist {
  display: grid;
  gap: 0.6rem;
}

.service-summary__list li,
.checklist li {
  position: relative;
  padding-left: 1rem;
  color: var(--clr-text-muted);
  line-height: 1.65;
}

.service-summary__list li::before,
.checklist li::before {
  content: '›';
  position: absolute;
  left: 0;
  color: var(--clr-accent);
  font-weight: 700;
}

.service-summary__badges,
.evidence-links__items {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.section-stack {
  display: grid;
  gap: 1.5rem;
}

.service-principle {
  display: grid;
  gap: 0.75rem;
}

.brief-card {
  display: grid;
  align-content: start;
  gap: 1rem;
}

.brief-card > :where(.card-title, .body-copy, .risk-note, .landing-cta-group) {
  margin: 0;
}

.brief-card .landing-cta-group {
  padding-top: 0.35rem;
}

.service-principle p {
  color: var(--clr-text-muted);
  line-height: 1.75;
}

.service-principle__headline {
  font-family: var(--ff-heading);
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--clr-accent) !important;
  line-height: 1.3 !important;
}

.risk-note {
  border: 1px solid var(--clr-border);
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.03);
  padding: var(--sp-4, 1rem);
}

.risk-note p {
  margin: 0;
  color: var(--clr-text-faint);
  font-size: 0.84rem;
  line-height: 1.65;
}

.tools-note,
.access-note,
.outreach-note {
  border: 1px solid rgba(196, 160, 74, 0.16);
  border-radius: var(--radius-md);
  background: rgba(196, 160, 74, 0.04);
  padding: var(--sp-6);
}

.tools-note {
  display: grid;
  gap: 0.55rem;
}

.tools-note p,
.access-note p,
.outreach-note p {
  color: var(--clr-text-muted);
  line-height: 1.75;
}

.access-note h3 {
  font-family: var(--ff-heading);
  font-size: 1rem;
  margin-bottom: 0.5rem;
}

.review-groups {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: var(--sp-6);
}

.review-group-list {
  display: flex;
  flex-direction: column;
  gap: 0.65rem;
}

.review-group-list li {
  position: relative;
  padding-left: 1rem;
  color: var(--clr-text-muted);
  line-height: 1.65;
  font-size: 0.88rem;
}

.review-group-list li::before {
  content: '›';
  position: absolute;
  left: 0;
  color: var(--clr-accent);
  font-weight: 700;
}

.service-review-grid,
.plans-grid {
  display: grid;
  gap: var(--sp-6);
}

.service-review-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.service-review-grid--cases {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.plans-grid {
  display: none;
}

.commercial-paths {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.commercial-path {
  display: grid;
  align-content: start;
  gap: 0.75rem;
}

.commercial-path:first-child {
  border-color: rgba(196, 160, 74, 0.34);
  background: linear-gradient(180deg, rgba(196, 160, 74, 0.09), rgba(255, 255, 255, 0.03));
}

.commercial-path__price {
  font-family: var(--ff-heading);
  font-size: 1.55rem !important;
  font-weight: 700;
  letter-spacing: -0.04em;
  line-height: 1;
  color: var(--clr-accent) !important;
}

.pricing-detail {
  padding-top: 0.5rem;
}

.decoy-note {
  display: grid;
  grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
  gap: var(--sp-6);
  align-items: start;
  border: 1px solid rgba(196, 160, 74, 0.22);
  border-left: 3px solid var(--clr-accent);
  border-radius: var(--radius-md);
  background: rgba(196, 160, 74, 0.045);
  padding: var(--sp-6);
}

.decoy-note h3 {
  font-size: clamp(1.1rem, 2vw, 1.55rem);
  margin-top: 0.35rem;
}

.faq-accordion {
  display: grid;
  gap: 0;
  border-top: 1px solid var(--clr-border);
}

.faq-item {
  border-bottom: 1px solid var(--clr-border);
}

.faq-item[open] {
  background: rgba(255, 255, 255, 0.01);
}

.faq-question {
  padding: 1rem var(--sp-4);
  font-family: var(--ff-heading);
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--clr-text);
  cursor: pointer;
  list-style: none;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 1rem;
  letter-spacing: -0.02em;
  transition: color 150ms;
}

.faq-question:hover {
  color: var(--clr-accent);
}

.faq-question::-webkit-details-marker {
  display: none;
}

.faq-question::after {
  content: '+';
  font-family: var(--ff-label);
  font-size: 1rem;
  color: var(--clr-accent);
  opacity: 0.5;
  flex-shrink: 0;
  transition: transform 200ms, opacity 150ms;
}

.faq-item[open] .faq-question::after {
  content: '−';
  opacity: 0.7;
}

.faq-answer {
  padding: 0 var(--sp-4) 1.25rem;
  font-size: 0.88rem;
  line-height: 1.7;
  color: var(--clr-text-muted);
  max-width: 68ch;
}

.plan-card {
  display: grid;
  gap: 0.85rem;
  position: relative;
}

.plan-card--accent {
  border-color: rgba(196, 160, 74, 0.24);
  background: linear-gradient(180deg, rgba(196, 160, 74, 0.06), rgba(255, 255, 255, 0.03));
}

.plan-card__flag {
  position: absolute;
  top: var(--sp-6);
  right: var(--sp-6);
  padding: 0.25rem 0.55rem;
  border: 1px solid rgba(196, 160, 74, 0.26);
  border-radius: var(--radius-sm);
  background: rgba(196, 160, 74, 0.08);
  color: var(--clr-accent);
  font-family: var(--ff-label);
  font-size: 0.64rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.plan-card__price {
  font-family: var(--ff-label);
  font-size: 0.88rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--clr-accent);
}

.plan-card__approx {
  margin-top: -0.55rem;
  color: var(--clr-text-faint);
  font-size: 0.82rem;
  line-height: 1.5;
}

.plan-card__intro,
.plan-card__note {
  color: var(--clr-text-muted);
  line-height: 1.7;
}

.plan-card__note {
  font-size: 0.82rem;
  color: var(--clr-text-faint);
}

.evidence-links,
.own-credential {
  display: grid;
  gap: 0.85rem;
}

.section-subheader {
  display: grid;
  gap: 0.4rem;
  padding-top: 0.5rem;
  border-top: 1px solid var(--clr-border);
}

.section-subheader__title {
  font-family: var(--ff-heading);
  font-size: 1.1rem;
  font-weight: 600;
}

.diff-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--sp-6);
}

.diff-grid__label {
  font-family: var(--ff-label);
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: 0.75rem;
}

.diff-grid__label--alt {
  color: var(--clr-text-faint);
}

.diff-grid__label--accent {
  color: var(--clr-accent);
}

.pricing-compare-wrapper {
  display: block;
  overflow-x: auto;
  border: 1px solid var(--clr-border);
  border-radius: var(--radius-md);
}

.pricing-compare__table {
  width: 100%;
  border-collapse: collapse;
  min-width: 720px;
}

.pricing-compare__feature-col {
  width: 28%;
}

.pricing-compare__plan {
  text-align: center;
  padding: var(--sp-4) var(--sp-3);
  border-bottom: 1px solid var(--clr-border);
  border-left: 1px solid var(--clr-border);
  vertical-align: top;
}

.pricing-compare__plan--recommended {
  background: rgba(196, 160, 74, 0.05);
  border-top: 2px solid var(--clr-accent);
}

.pricing-compare__plan-price {
  display: block;
  font-family: var(--ff-label);
  font-size: 0.82rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--clr-accent);
  margin-bottom: 0.3rem;
}

.pricing-compare__plan-name {
  display: block;
  font-family: var(--ff-heading);
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--clr-text);
  line-height: 1.35;
}

.pricing-compare__recommended-badge {
  display: inline-block;
  margin-top: 0.4rem;
  padding: 0.15rem 0.45rem;
  border: 1px solid rgba(196, 160, 74, 0.26);
  border-radius: var(--radius-sm);
  background: rgba(196, 160, 74, 0.08);
  color: var(--clr-accent);
  font-family: var(--ff-label);
  font-size: 0.6rem;
  letter-spacing: 0.07em;
  text-transform: uppercase;
}

.pricing-compare__feature {
  padding: var(--sp-3) var(--sp-4);
  border-top: 1px solid var(--clr-border);
  color: var(--clr-text-muted);
  font-size: 0.84rem;
  line-height: 1.5;
}

.pricing-compare__check {
  text-align: center;
  padding: var(--sp-3);
  border-top: 1px solid var(--clr-border);
  border-left: 1px solid var(--clr-border);
  font-size: 0.88rem;
}

.pricing-compare__check--yes {
  color: var(--clr-accent);
  font-weight: 600;
}

.pricing-compare__check--no {
  color: var(--clr-text-faint);
}

.pricing-compare__plan--recommended ~ .pricing-compare__check,
td.pricing-compare__check:nth-child(5) {
  background: rgba(196, 160, 74, 0.03);
}

.pricing-footnote {
  max-width: 68rem;
  color: var(--clr-text-faint);
  font-size: 0.82rem;
  line-height: 1.7;
}

.final-action {
  max-width: 48rem;
  border-color: rgba(196, 160, 74, 0.24);
  background:
    linear-gradient(180deg, rgba(196, 160, 74, 0.07), rgba(255, 255, 255, 0.03));
}

.sample-report {
  border: 1px solid var(--clr-border);
  border-radius: var(--radius-md);
  overflow: hidden;
  background: rgba(255, 255, 255, 0.025);
}

.sample-report__header {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: start;
  padding: var(--sp-6);
  border-bottom: 1px solid var(--clr-border);
}

.sample-report__header h3 {
  font-family: var(--ff-heading);
  font-size: 1.1rem;
  margin-top: 0.25rem;
}

.sample-report__table {
  display: grid;
}

.sample-report__row {
  display: grid;
  grid-template-columns: 1.1fr 1fr 1.35fr 0.7fr;
  gap: 1rem;
  padding: 0.95rem var(--sp-6);
  border-bottom: 1px solid var(--clr-border);
}

.sample-report__row:last-child {
  border-bottom: none;
}

.sample-report__row span {
  min-width: 0;
  color: var(--clr-text-muted);
  font-size: 0.84rem;
  line-height: 1.55;
}

.sample-report__row--head span {
  color: var(--clr-text-faint);
  font-family: var(--ff-label);
  font-size: 0.68rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

/* Executive report mock */
.exec-report {
  border: 1px solid var(--clr-border);
  border-top: 3px solid var(--clr-accent);
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.025);
  overflow: hidden;
}

.exec-report__header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 1rem;
  padding: var(--sp-6);
  border-bottom: 1px solid var(--clr-border);
}

.exec-report__eyebrow {
  font-family: var(--ff-label);
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--clr-text-faint);
  margin-bottom: 0.3rem;
}

.exec-report__title {
  font-family: var(--ff-heading);
  font-size: 1.1rem;
  font-weight: 600;
}

.exec-report__header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.5rem;
  flex-shrink: 0;
}

.exec-report__date {
  font-family: var(--ff-label);
  font-size: 0.7rem;
  letter-spacing: 0.04em;
  color: var(--clr-text-faint);
}

.exec-report__scores {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  padding: var(--sp-6);
  border-bottom: 1px solid var(--clr-border);
  background: rgba(255, 255, 255, 0.02);
}

.exec-report__score-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.35rem;
}

.exec-report__score-item--stat {
  margin-left: auto;
  align-items: flex-end;
}

.exec-report__score {
  font-family: var(--ff-heading);
  font-size: 2.2rem;
  font-weight: 700;
  line-height: 1;
  letter-spacing: -0.04em;
  width: 2.8rem;
  height: 2.8rem;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-sm);
}

.exec-report__score--before {
  background: rgba(200, 80, 60, 0.12);
  color: rgba(220, 100, 80, 0.9);
  border: 1px solid rgba(200, 80, 60, 0.2);
}

.exec-report__score--after {
  background: rgba(196, 160, 74, 0.1);
  color: var(--clr-accent);
  border: 1px solid rgba(196, 160, 74, 0.22);
}

.exec-report__score-label {
  font-size: 0.72rem;
  color: var(--clr-text-faint);
  text-align: center;
  line-height: 1.4;
}

.exec-report__arrow {
  font-size: 1.2rem;
  color: var(--clr-text-faint);
  opacity: 0.5;
}

.exec-report__stat {
  font-family: var(--ff-heading);
  font-size: 1.6rem;
  font-weight: 700;
  letter-spacing: -0.03em;
  color: var(--clr-accent);
  line-height: 1;
}

.exec-report__findings {
  display: grid;
}

.exec-report__finding {
  display: grid;
  grid-template-columns: 8rem minmax(0, 1fr);
  gap: 1rem;
  padding: 1rem var(--sp-6);
  border-bottom: 1px solid var(--clr-border);
  align-items: start;
}

.exec-report__finding:last-child {
  border-bottom: none;
}

.exec-report__finding--pending {
  background: rgba(255, 255, 255, 0.015);
}

.exec-report__status {
  font-family: var(--ff-label);
  font-size: 0.64rem;
  font-weight: 600;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  padding: 0.25rem 0.5rem;
  border-radius: var(--radius-sm);
  justify-self: start;
  margin-top: 0.15rem;
  white-space: nowrap;
}

.exec-report__status--resolved {
  background: rgba(196, 160, 74, 0.1);
  color: var(--clr-accent);
  border: 1px solid rgba(196, 160, 74, 0.2);
}

.exec-report__status--pending {
  background: rgba(255, 255, 255, 0.05);
  color: var(--clr-text-muted);
  border: 1px solid var(--clr-border);
}

.exec-report__finding-title {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--clr-text);
  margin-bottom: 0.35rem;
  line-height: 1.4;
}

.exec-report__finding-impact {
  font-size: 0.84rem;
  color: var(--clr-text-muted);
  line-height: 1.65;
}

.exec-report__footer {
  padding: var(--sp-6);
  border-top: 1px solid var(--clr-border);
  background: rgba(196, 160, 74, 0.03);
}

.exec-report__footer p {
  font-size: 0.82rem;
  color: var(--clr-text-faint);
  line-height: 1.65;
  font-style: italic;
}

@media (max-width: 980px) {
  .service-hero__grid,
  .diagnostic-band,
  .symptom-grid,
  .decision-grid,
  .commercial-paths,
  .judgment-grid,
  .decoy-note,
  .review-groups,
  .service-review-grid,
  .service-review-grid--cases,
  .diff-grid {
    grid-template-columns: 1fr;
  }

  .diagnostic-band {
    align-items: stretch;
  }

  .diagnostic-band__cta {
    justify-self: start;
  }

  .pricing-compare-wrapper {
    display: none;
  }

  .plans-grid {
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: var(--sp-4);
    padding-bottom: var(--sp-3);
    -webkit-overflow-scrolling: touch;
  }

  .plans-grid .plan-card {
    flex: 0 0 85vw;
    scroll-snap-align: start;
  }

  .sample-report__row {
    grid-template-columns: 1fr;
    gap: 0.35rem;
  }

  .sample-report__row--head {
    display: none;
  }
}

