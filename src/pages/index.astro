<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tooltician — Python Automation Consultant | English / Español</title>
  <meta name="description" content="Tooltician automates reporting, ETL, and internal workflows that survive handoff. Select English or Spanish to view live production work and open a project brief." />
  <link rel="canonical" href="https://tooltician.com/" />
  <link rel="alternate" hreflang="es" href="https://tooltician.com/es/" />
  <link rel="alternate" hreflang="en" href="https://tooltician.com/en/" />
  <link rel="alternate" hreflang="x-default" href="https://tooltician.com/" />
  <meta name="robots" content="index, follow" />
  <noscript><meta http-equiv="refresh" content="0; url=/en/" /></noscript>
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Tooltician — Python Automation Consultant | English / Español" />
  <meta property="og:description" content="Tooltician automates reporting, ETL, and internal workflows that survive handoff. Select English or Spanish." />
  <meta property="og:url" content="https://tooltician.com/" />
  <meta property="og:image" content="https://tooltician.com/assets/images/og-card.png" />
  <meta property="og:image:alt" content="Tooltician preview card" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Tooltician — Python Automation Consultant | English / Español" />
  <meta name="twitter:description" content="Tooltician automates reporting, ETL, and internal workflows that survive handoff. Select English or Spanish." />
  <meta name="twitter:image" content="https://tooltician.com/assets/images/og-card.png" />
  <meta name="twitter:image:alt" content="Tooltician preview card" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
  <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
  <meta name="theme-color" content="#0b1121" />
  <link rel="preload" href="/fonts/archivo-variable.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/jetbrains-mono-variable.woff2" as="font" type="font/woff2" crossorigin />
  <script is:inline src="/assets/js/root-language-redirect.js"></script>
  <style>
    :root {
      color-scheme: dark;
      --bg: #0b1121;
      --surface: rgba(255, 255, 255, 0.03);
      --border: rgba(148, 163, 184, 0.12);
      --text: #f1f5f9;
      --muted: #94a3b8;
      --faint: #64748b;
      --accent: #c4a04a;
      --ff-body: 'Archivo', system-ui, sans-serif;
      --ff-heading: 'Archivo', system-ui, sans-serif;
      --ff-label: 'JetBrains Mono', ui-monospace, monospace;
    }

    @font-face {
      font-family: 'Archivo';
      src: url('/fonts/archivo-variable.woff2') format('woff2');
      font-style: normal;
      font-weight: 100 900;
      font-display: swap;
    }

    @font-face {
      font-family: 'JetBrains Mono';
      src: url('/fonts/jetbrains-mono-variable.woff2') format('woff2');
      font-style: normal;
      font-weight: 100 800;
      font-display: swap;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: var(--ff-body);
      color: var(--text);
      background: var(--bg);
      display: grid;
      place-items: center;
      padding: 1.5rem;
    }

    ::selection {
      background: rgba(196, 160, 74, 0.25);
      color: var(--text);
    }

    .gateway-panel {
      width: min(100%, 520px);
      border: 1px solid var(--border);
      border-radius: 6px;
      background: var(--surface);
      overflow: hidden;
    }

    .gateway-panel__body {
      padding: 2.5rem 2rem 2rem;
    }

    .gateway-panel__logo-area {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      margin-bottom: 2rem;
    }

    .gateway-panel__logo {
      width: 40px;
      height: 40px;
      flex-shrink: 0;
    }

    .gateway-panel__brand {
      display: grid;
      gap: 0.1rem;
    }

    .gateway-panel__brand-name {
      font-family: var(--ff-heading);
      font-size: 1.25rem;
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1;
    }

    .gateway-panel__brand-tag {
      font-family: var(--ff-label);
      font-size: 0.6rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      opacity: 0.7;
    }

    .gateway-panel__title {
      margin: 0 0 0.75rem;
      font-family: var(--ff-heading);
      font-size: clamp(1.5rem, 4vw, 2rem);
      line-height: 0.92;
      letter-spacing: -0.03em;
    }

    .gateway-panel__copy {
      margin: 0 0 2rem;
      color: var(--muted);
      font-size: 0.9rem;
      line-height: 1.65;
    }

    .gateway-panel__options {
      display: grid;
      gap: 0.75rem;
    }

    .gateway-panel__card {
      display: block;
      padding: 1.1rem 1.25rem;
      border: 1px solid var(--border);
      border-radius: 6px;
      color: inherit;
      text-decoration: none;
      transition: border-color 200ms, background 200ms;
    }

    .gateway-panel__card:hover,
    .gateway-panel__card:focus-visible {
      border-color: rgba(196, 160, 74, 0.25);
      background: rgba(196, 160, 74, 0.04);
      outline: none;
    }

    .gateway-panel__card:active {
      background: rgba(196, 160, 74, 0.08);
    }

    .gateway-panel__card strong {
      display: block;
      margin-bottom: 0.35rem;
      font-family: var(--ff-heading);
      font-size: 1.05rem;
      font-weight: 700;
    }

    .gateway-panel__card strong::after {
      content: ' →';
      opacity: 0;
      transition: opacity 200ms, margin-left 200ms;
    }

    .gateway-panel__card:hover strong::after,
    .gateway-panel__card:focus-visible strong::after {
      opacity: 1;
      margin-left: 0.25rem;
    }

    .gateway-panel__card span {
      color: var(--muted);
      line-height: 1.55;
      font-size: 0.85rem;
      display: block;
    }

    .gateway-panel__footer {
      padding: 1rem 2rem;
      border-top: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .gateway-panel__footer-note {
      margin: 0;
      color: var(--faint);
      font-family: var(--ff-label);
      font-size: 0.6rem;
      letter-spacing: 0.04em;
    }

    .gateway-panel__cursor {
      display: inline-block;
      width: 6px;
      height: 12px;
      background: var(--accent);
      opacity: 0.5;
      animation: blink 1s step-end infinite;
    }

    @keyframes blink {
      0%, 100% { opacity: 0.5; }
      50% { opacity: 0; }
    }

    @media (max-width: 700px) {
      .gateway-panel__body {
        padding: 1.5rem 1.25rem;
      }
      .gateway-panel__footer {
        padding: 1rem 1.25rem;
        flex-direction: column;
        gap: 0.5rem;
        align-items: flex-start;
      }
    }
  </style>
</head>
<body>
  <div class="gateway-panel">
    <div class="gateway-panel__body">
      <div class="gateway-panel__logo-area">
        <img class="gateway-panel__logo" src="/assets/images/tooltician-logo-128.webp" alt="" width="40" height="40" decoding="async">
        <div class="gateway-panel__brand">
          <span class="gateway-panel__brand-name">Tooltician</span>
          <span class="gateway-panel__brand-tag">Automation systems</span>
        </div>
      </div>

      <h1 class="gateway-panel__title">English / Español</h1>
      <p class="gateway-panel__copy">First visits are auto-routed from browser language. Choose once below and the site will remember your preference.</p>

      <div class="gateway-panel__options">
        <a class="gateway-panel__card" href="/en/" data-language-preference="en">
          <strong>English</strong>
          <span>Proof, production work, and a direct project brief.</span>
        </a>
        <a class="gateway-panel__card" href="/es/" data-language-preference="es">
          <strong>Español</strong>
          <span>Evidencia pública, trabajo en producción y brief directo.</span>
        </a>
      </div>
    </div>

    <div class="gateway-panel__footer">
      <p class="gateway-panel__footer-note">Your choice is remembered for future visits.</p>
      <span class="gateway-panel__cursor"></span>
    </div>
  </div>
  <script is:inline src="/assets/js/root-language-picker.js" defer></script>
</body>
</html>
