---
// This is a static site (GitHub Pages), so we must use a meta refresh redirect
// instead of a server-side SSR GET() function.
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Redirecting...</title>
  <script>
    const userLang = navigator.language || navigator.userLanguage;
    if (userLang && userLang.toLowerCase().startsWith('es')) {
      window.location.replace('/es/');
    } else {
      window.location.replace('/en/');
    }
  </script>
  <noscript>
    <meta http-equiv="refresh" content="0;url=/en/" />
  </noscript>
  <link rel="canonical" href="https://tooltician.com/en/" />
</head>
<body>
  <p>Redirecting... / Redirigiendo...</p>
</body>
</html>
