<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tooltician — English / Español</title>
  <meta name="description" content="Choose the English or Spanish version of Tooltician, Carlos Ortega's Python automation consulting site." />
  <link rel="canonical" href="https://tooltician.com/" />
  <link rel="alternate" hreflang="es" href="https://tooltician.com/es/" />
  <link rel="alternate" hreflang="en" href="https://tooltician.com/en/" />
  <link rel="alternate" hreflang="x-default" href="https://tooltician.com/" />
  <meta name="robots" content="index, follow" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Tooltician — English / Español" />
  <meta property="og:description" content="Choose the English or Spanish version of Tooltician, Carlos Ortega's Python automation consulting site." />
  <meta property="og:url" content="https://tooltician.com/" />
  <meta property="og:image" content="https://tooltician.com/assets/images/og-card.png" />
  <meta property="og:image:alt" content="Tooltician preview card" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Tooltician — English / Español" />
  <meta name="twitter:description" content="Choose the English or Spanish version of Tooltician, Carlos Ortega's Python automation consulting site." />
  <meta name="twitter:image" content="https://tooltician.com/assets/images/og-card.png" />
  <meta name="twitter:image:alt" content="Tooltician preview card" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
  <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500;600&family=IBM+Plex+Sans:wght@400;500;600;700&family=Newsreader:opsz,wght@6..72,600;6..72,700&display=swap" rel="stylesheet" />
  <script>
    (() => {
      const preferenceKey = 'tooltician-language';
      const firstVisitKey = 'tooltician-language-autoredirect';
      const normalizeLanguage = (value: string | null) => {
        if (typeof value !== 'string') return null;

        const lower = value.toLowerCase();
        if (lower.startsWith('es')) return 'es';
        if (lower.startsWith('en')) return 'en';
        return null;
      };

      try {
        const storedPreference = normalizeLanguage(window.localStorage.getItem(preferenceKey));
        const autoRedirected = window.localStorage.getItem(firstVisitKey) === '1';
        const browserPreference = [...(navigator.languages ?? []), navigator.language ?? '']
          .map(normalizeLanguage)
          .find(Boolean) ?? 'en';
        const target = storedPreference ?? (autoRedirected ? null : browserPreference);

        if (!storedPreference && !autoRedirected) {
          window.localStorage.setItem(firstVisitKey, '1');
        }

        if (target) {
          window.location.replace(`/${target}/`);
        }
      } catch {
        // Fall back to showing the language gateway.
      }
    })();
  </script>
  <style>
    :root {
      color-scheme: light;
      --bg: #f3ecdf;
      --surface: rgba(255, 255, 255, 0.72);
      --surface-2: rgba(255, 255, 255, 0.48);
      --border: rgba(32, 26, 21, 0.12);
      --text: #201a15;
      --muted: #5d554a;
      --accent: #9a4d2a;
      --accent-2: #29574e;
      --ff-body: 'IBM Plex Sans', system-ui, sans-serif;
      --ff-heading: 'Newsreader', Georgia, serif;
      --ff-label: 'IBM Plex Mono', monospace;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: var(--ff-body);
      color: var(--text);
      background: linear-gradient(180deg, #f8f2e8 0%, #f0e5d7 54%, #eadfce 100%);
      display: grid;
      place-items: center;
      padding: 1.5rem;
    }

    .gateway {
      width: min(100%, 920px);
      padding: 2.25rem;
      border: 1px solid var(--border);
      border-radius: 20px;
      background: var(--surface);
      box-shadow: 0 12px 28px rgba(32, 26, 21, 0.06);
      text-align: center;
    }

    .gateway__logo {
      width: 64px;
      height: 64px;
      margin-bottom: 1rem;
    }

    .gateway__eyebrow {
      margin: 0 0 0.75rem;
      color: var(--accent-2);
      font-family: var(--ff-label);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .gateway__title {
      margin: 0 0 0.75rem;
      font-family: var(--ff-heading);
      font-size: clamp(2.35rem, 6vw, 4rem);
      line-height: 0.96;
      letter-spacing: -0.04em;
    }

    .gateway__copy {
      margin: 0 auto 1.5rem;
      max-width: 42rem;
      color: var(--muted);
      font-size: 1.02rem;
      line-height: 1.7;
    }

    .gateway__options {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .gateway__card {
      display: block;
      padding: 1.3rem;
      border: 1px solid var(--border);
      border-radius: 12px;
      background: var(--surface-2);
      color: inherit;
      text-decoration: none;
      transition: transform 150ms ease, border-color 150ms ease, background 150ms ease, box-shadow 150ms ease;
    }

    .gateway__card:hover,
    .gateway__card:focus-visible {
      transform: none;
      border-color: rgba(154, 77, 42, 0.24);
      background: rgba(255, 255, 255, 0.72);
      box-shadow: 0 8px 18px rgba(32, 26, 21, 0.04);
      outline: none;
    }

    .gateway__card strong {
      display: block;
      margin-bottom: 0.45rem;
      font-family: var(--ff-heading);
      font-size: 1.45rem;
      font-weight: 700;
    }

    .gateway__card span {
      color: var(--muted);
      line-height: 1.55;
      font-size: 0.95rem;
    }

    .gateway__note {
      margin: 0;
      color: var(--muted);
      font-size: 0.92rem;
    }

    @media (max-width: 700px) {
      .gateway {
        padding: 1.5rem;
        border-radius: 24px;
      }

      .gateway__options {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <main class="gateway">
    <img class="gateway__logo" src="/assets/images/tooltician-logo-128.webp" alt="" width="64" height="64" decoding="async">
    <p class="gateway__eyebrow">Tooltician · Carlos Ortega Gonzalez</p>
    <h1 class="gateway__title">Choose your language</h1>
    <p class="gateway__copy">Python automation consulting for reporting, ETL, internal tools, and workflows that need to keep working after handoff.</p>

    <div class="gateway__options">
      <a class="gateway__card" href="/en/" data-language-preference="en">
        <strong>English</strong>
        <span>Production-focused portfolio, public proof, and a direct project brief.</span>
      </a>
      <a class="gateway__card" href="/es/" data-language-preference="es">
        <strong>Español</strong>
        <span>Portafolio orientado a producción, evidencia pública y brief de proyecto directo.</span>
      </a>
    </div>

    <p class="gateway__note">If the first automatic guess was wrong, choose once and the site will remember it.</p>
  </main>
  <script>
    (() => {
      const preferenceKey = 'tooltician-language';
      const firstVisitKey = 'tooltician-language-autoredirect';

      document.querySelectorAll('[data-language-preference]').forEach(link => {
        link.addEventListener('click', () => {
          const preference = link.getAttribute('data-language-preference');
          if (!preference) return;

          try {
            window.localStorage.setItem(preferenceKey, preference);
            window.localStorage.setItem(firstVisitKey, '1');
          } catch {
            // Ignore storage failures and keep normal navigation.
          }
        });
      });
    })();
  </script>
</body>
</html>
