---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---
<BaseLayout
  title="Tooltician | Carlos Ortega Gonzalez"
  description="Python automation and data systems consultant. Production-ready ETL, scraping, APIs, and reporting workflows."
  lang="en"
  canonical="https://tooltician.com/"
>
  <main class="landing-root" id="main">
    <div class="landing-bg" aria-hidden="true">
      <div class="landing-orb landing-orb--1"></div>
      <div class="landing-orb landing-orb--2"></div>
      <div class="landing-grid"></div>
    </div>

    <div class="landing-content">
      <header class="landing-header">
        <p class="landing-eyebrow">Tooltician</p>
        <h1 class="landing-name">Carlos Ortega Gonzalez</h1>
        <p class="landing-role">Python automation &amp; data systems consultant</p>
        <p class="landing-location">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="vertical-align:middle;margin-right:4px">
            <path d="M20 10c0 6-8 13-8 13s-8-7-8-13a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
          </svg>
          Santiago, Chile
        </p>
        <div class="landing-links">
          <a href="https://github.com/cortega26" target="_blank" rel="noopener noreferrer">GitHub</a>
          <span aria-hidden="true">·</span>
          <a href="https://www.linkedin.com/in/cortega26" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <span aria-hidden="true">·</span>
          <a href="mailto:carlosortega77@gmail.com">Email</a>
        </div>
      </header>

      <p class="landing-choose">Choose your language / Elige tu idioma</p>

      <div class="landing-grid-cards" id="language-options">
        <a class="lang-card" href="/en/">
          <div class="lang-card__flag" aria-hidden="true">EN</div>
          <div class="lang-card__body">
            <h2 class="lang-card__title">English</h2>
            <p class="lang-card__desc">Full portfolio, project case studies, and contact options for international clients.</p>
          </div>
          <div class="lang-card__arrow" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14m0 0-6-6m6 6-6 6"/>
            </svg>
          </div>
        </a>

        <a class="lang-card" href="/es/">
          <div class="lang-card__flag lang-card__flag--es" aria-hidden="true">ES</div>
          <div class="lang-card__body">
            <h2 class="lang-card__title">Español</h2>
            <p class="lang-card__desc">Portafolio completo, proyectos destacados y formas de contacto en español.</p>
          </div>
          <div class="lang-card__arrow" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14m0 0-6-6m6 6-6 6"/>
            </svg>
          </div>
        </a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
/* ---- Landing Page ---- */
.landing-root {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  padding: 2rem;
}

/* Animated background */
.landing-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
}
.landing-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(108,99,255,0.06) 1px, transparent 1px),
    linear-gradient(90deg, rgba(108,99,255,0.06) 1px, transparent 1px);
  background-size: 60px 60px;
  mask-image: radial-gradient(ellipse at center, black 20%, transparent 80%);
}
.landing-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.4;
  animation: float-orb 8s ease-in-out infinite;
}
.landing-orb--1 {
  width: 500px; height: 500px;
  background: radial-gradient(circle, #6c63ff 0%, transparent 70%);
  top: -150px; left: -100px;
  animation-delay: 0s;
}
.landing-orb--2 {
  width: 400px; height: 400px;
  background: radial-gradient(circle, #00d4aa 0%, transparent 70%);
  bottom: -100px; right: -80px;
  animation-delay: 4s;
}
@keyframes float-orb {
  0%, 100% { transform: translate(0, 0) scale(1); }
  50% { transform: translate(20px, -20px) scale(1.05); }
}

/* Content */
.landing-content {
  position: relative;
  z-index: 1;
  text-align: center;
  max-width: 600px;
  width: 100%;
}

.landing-eyebrow {
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--clr-accent);
  margin-bottom: 0.75rem;
  animation: fade-up 0.6s ease-out both;
}
.landing-name {
  font-family: var(--ff-heading);
  font-size: clamp(2rem, 6vw, 3.5rem);
  font-weight: 700;
  line-height: 1.1;
  margin-bottom: 0.5rem;
  background: linear-gradient(135deg, #fff 40%, var(--clr-accent));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: fade-up 0.6s ease-out 0.1s both;
}
.landing-role {
  font-size: clamp(1rem, 2.5vw, 1.2rem);
  color: var(--clr-text-muted);
  margin-bottom: 0.5rem;
  animation: fade-up 0.6s ease-out 0.2s both;
}
.landing-location {
  font-size: 0.875rem;
  color: var(--clr-text-faint);
  margin-bottom: 1.25rem;
  animation: fade-up 0.6s ease-out 0.25s both;
}
.landing-links {
  display: flex;
  gap: 0.75rem;
  justify-content: center;
  align-items: center;
  margin-bottom: 2.5rem;
  animation: fade-up 0.6s ease-out 0.3s both;
}
.landing-links a {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--clr-accent);
  transition: color 150ms;
}
.landing-links a:hover { color: #a09aff; }
.landing-links span { color: var(--clr-text-faint); }

.landing-choose {
  font-size: 0.8rem;
  color: var(--clr-text-faint);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 1.25rem;
  animation: fade-up 0.6s ease-out 0.35s both;
}

.landing-grid-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.25rem;
  animation: fade-up 0.6s ease-out 0.45s both;
}

.lang-card {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  padding: 1.75rem 1.5rem;
  background: var(--clr-bg-card);
  border: 1px solid var(--clr-border);
  border-radius: var(--radius-lg);
  backdrop-filter: blur(12px);
  text-align: left;
  transition: background 300ms, border-color 300ms, transform 300ms, box-shadow 300ms;
  cursor: pointer;
  position: relative;
  overflow: hidden;
}
.lang-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(108,99,255,0.1) 0%, transparent 60%);
  opacity: 0;
  transition: opacity 300ms;
}
.lang-card:hover::before { opacity: 1; }
.lang-card:hover {
  background: var(--clr-bg-card-hover);
  border-color: var(--clr-border-glow);
  transform: translateY(-4px);
  box-shadow: var(--shadow-glow), var(--shadow-card);
}

.lang-card__flag {
  width: 42px; height: 42px;
  border-radius: 10px;
  background: rgba(108, 99, 255, 0.2);
  border: 1px solid rgba(108, 99, 255, 0.3);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--ff-heading);
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--clr-accent);
  letter-spacing: 0.08em;
}
.lang-card__flag--es {
  background: rgba(0, 212, 170, 0.15);
  border-color: rgba(0, 212, 170, 0.3);
  color: var(--clr-accent-2);
}

.lang-card__body { flex: 1; }

.lang-card__title {
  font-family: var(--ff-heading);
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--clr-text);
  margin-bottom: 0.4rem;
}
.lang-card__desc {
  font-size: 0.875rem;
  color: var(--clr-text-muted);
  line-height: 1.5;
}
.lang-card__arrow {
  color: var(--clr-text-muted);
  align-self: flex-end;
  transition: transform 300ms, color 300ms;
}
.lang-card:hover .lang-card__arrow {
  color: var(--clr-accent);
  transform: translateX(4px);
}

@keyframes fade-up {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}

@media (max-width: 520px) {
  .landing-grid-cards { grid-template-columns: 1fr; }
}
</style>
